<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
	<Package Name="Autoprint Server" Manufacturer="Autoprint" Version="1.1.1.0" UpgradeCode="a6f8f87a-9c9d-4e9f-8b8a-1234567890ab">
		<MajorUpgrade DowngradeErrorMessage="Une version plus récente est déjà installée." />

		<MediaTemplate EmbedCab="yes" />

		<StandardDirectory Id="ProgramFiles64Folder">
			<Directory Id="INSTALLFOLDER" Name="Autoprint Server" />
		</StandardDirectory>

		<Feature Id="Main">
			<ComponentGroupRef Id="AppFiles" />
			<ComponentGroupRef Id="ConfigFiles" />
		</Feature>

		<ui:WixUI Id="WixUI_InstallDir" />
		<Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
	</Package>
</Wix>