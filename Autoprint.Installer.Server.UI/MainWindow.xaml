<Window x:Class="Autoprint.Installer.Server.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Installation Autoprint Server" Height="650" Width="800"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize"
        Background="#F5F5F5" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2D2D30">
            <StackPanel VerticalAlignment="Center" Margin="25,0">
                <TextBlock Text="AUTOPRINT SERVER" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TxtStepTitle" Text="Assistant d'Installation" FontSize="14" Foreground="#AAAAAA"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="30,20">

            <StackPanel x:Name="View1_Welcome">
                <TextBlock Text="Bienvenue" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>
                <TextBlock Text="Vous êtes sur le point d'installer Autoprint Server sur cet ordinateur." 
                           FontSize="16" Margin="0,0,0,20"/>
                <TextBlock Text="Cet assistant va configurer :" FontWeight="Bold" Margin="0,10,0,5"/>
                <StackPanel Margin="20,0,0,0">
                    <TextBlock Text="• Le service Backend et l'API" Margin="0,2"/>
                    <TextBlock Text="• Le serveur Web IIS" Margin="0,2"/>
                    <TextBlock Text="• La base de données" Margin="0,2"/>
                </StackPanel>
                <TextBlock Text="Cliquez sur Suivant pour continuer." FontStyle="Italic" Foreground="Gray" Margin="0,30,0,0"/>
            </StackPanel>

            <Grid x:Name="View2_License" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Contrat de Licence" FontSize="20" Margin="0,0,0,10"/>

                <RichTextBox x:Name="RtbLicense" Grid.Row="1" IsReadOnly="True" VerticalScrollBarVisibility="Auto" 
                             BorderBrush="#DDD" BorderThickness="1" Padding="10">
                    <FlowDocument />
                </RichTextBox>

                <CheckBox x:Name="ChkAcceptLicense" Grid.Row="2" Content="J'accepte les termes du contrat de licence" 
                          Margin="0,15,0,0" FontSize="14" FontWeight="SemiBold"/>
            </Grid>

            <StackPanel x:Name="View3_Prereqs" Visibility="Collapsed">
                <TextBlock Text="Vérification du Système" FontSize="20" Margin="0,0,0,15"/>
                <TextBlock Text="Le système vérifie la présence des composants nécessaires." Margin="0,0,0,10" Foreground="Gray"/>

                <Border Background="White" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3" Padding="15">
                    <StackPanel>
                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="IconIis" Text="⏳" VerticalAlignment="Center" FontSize="16"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="Rôle Serveur Web (IIS)" FontWeight="SemiBold"/>
                                <TextBlock x:Name="MsgIis" Text="Analyse..." FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                            <Button x:Name="BtnInstallIis" Grid.Column="2" Content="Installer" Padding="15,5" 
                                    Visibility="Collapsed" Click="BtnInstallIis_Click"/>
                        </Grid>

                        <Separator Background="#EEE"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="IconPrint" Text="⏳" VerticalAlignment="Center" FontSize="16"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="Rôle Serveur d'Impression" FontWeight="SemiBold"/>
                                <TextBlock x:Name="MsgPrint" Text="Analyse..." FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                            <Button x:Name="BtnInstallPrint" Grid.Column="2" Content="Installer" Padding="15,5" 
                                    Visibility="Collapsed" Click="BtnInstallPrint_Click"/>
                        </Grid>

                        <Separator Background="#EEE"/>

                        <Grid Margin="0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="IconNet" Text="⏳" VerticalAlignment="Center" FontSize="16"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="Runtime .NET 10 (Hosting Bundle)" FontWeight="SemiBold"/>
                                <TextBlock x:Name="MsgNet" Text="Analyse..." FontSize="12" Foreground="Gray"/>
                            </StackPanel>
                            <Button x:Name="BtnInstallNet" Grid.Column="2" Content="Installer" Padding="15,5" 
                                    Visibility="Collapsed" Click="BtnInstallNet_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="View4_Sql" Visibility="Collapsed">
                <TextBlock Text="Configuration Base de Données" FontSize="20" Margin="0,0,0,15"/>

                <RadioButton x:Name="RadioSqlite" GroupName="SqlGroup" Content="SQLite (Local - Fichier unique)" IsChecked="True" 
                             Margin="0,0,0,15" Checked="RadioSql_Changed"/>

                <RadioButton x:Name="RadioSqlServer" GroupName="SqlGroup" Content="SQL Server (Production)" 
                             Margin="0,0,0,10" Checked="RadioSql_Changed"/>

                <Border x:Name="PanelSqlServer" Background="White" BorderBrush="#DDD" BorderThickness="1" Padding="15" Margin="20,0,0,0" Visibility="Collapsed">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Serveur (Instance) :" VerticalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBox Grid.Column="1" x:Name="TxtSqlServer" Text="localhost" Padding="3" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Text="Nom de la base :" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSqlDb" Text="AutoprintDb" Padding="3"/>
                        </Grid>

                        <Separator Background="#EEE" Margin="0,5,0,10"/>

                        <TextBlock Text="Mode d'authentification :" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <ComboBox x:Name="ComboAuth" SelectedIndex="0" Margin="0,0,0,10" Padding="5" SelectionChanged="ComboAuth_SelectionChanged">
                            <ComboBoxItem Content="Authentification Windows (Intégrée)"/>
                            <ComboBoxItem Content="Authentification SQL Server (User/Pass)"/>
                        </ComboBox>

                        <Border x:Name="PanelSqlCreds" Visibility="Collapsed" Background="#F9F9F9" Padding="10" Margin="0,0,0,10" BorderBrush="#EEE" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Utilisateur (SA) :" VerticalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBox Grid.Column="1" x:Name="TxtSqlUser" Text="sa" Padding="3" Margin="0,0,0,10"/>

                                <TextBlock Grid.Row="1" Text="Mot de passe :" VerticalAlignment="Center"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="TxtSqlPass" Padding="3"/>
                            </Grid>
                        </Border>

                        <Button x:Name="BtnTestSql" Content="Tester la connexion" HorizontalAlignment="Right" Padding="20,5" Click="BtnTestSql_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel x:Name="View5_Iis" Visibility="Collapsed">
                <TextBlock Text="Configuration Web (IIS)" FontSize="20" Margin="0,0,0,15"/>
                <TextBlock Text="Définissez le port d'écoute pour l'application." Margin="0,0,0,10"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Port HTTP :" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox x:Name="TxtWebPort" Grid.Column="1" Text="8080" Padding="5" MaxLength="5"/>
                </Grid>
                <TextBlock Text="Note : L'installeur configurera le pare-feu automatiquement." FontSize="11" Foreground="Gray" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel x:Name="View6_Install" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock Text="Installation en cours..." FontSize="22" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <ProgressBar x:Name="PrgInstall" Height="15" IsIndeterminate="True" Width="400"/>
                <TextBlock x:Name="TxtInstallLog" Text="Préparation..." HorizontalAlignment="Center" Margin="0,10" Foreground="#666"/>
            </StackPanel>

            <StackPanel x:Name="View7_Finish" Visibility="Collapsed">
                <TextBlock Text="Installation Terminée" FontSize="24" Foreground="#2E7D32" Margin="0,0,0,20"/>
                <TextBlock Text="Autoprint Server a été installé et configuré avec succès." FontSize="14"/>

                <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                    <TextBlock Text="👉" Margin="0,0,10,0"/>
                    <TextBlock Text="Vous pouvez maintenant accéder à l'interface d'administration."/>
                </StackPanel>

                <Button x:Name="BtnOpenIis" Content="Ouvrir la console IIS" HorizontalAlignment="Left" Margin="0,20,0,0" Padding="15,8" Click="BtnOpenIis_Click"/>
            </StackPanel>

        </Grid>

        <Border Grid.Row="2" Background="#EFEFEF" BorderBrush="#DDD" BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Button x:Name="BtnPrev" Content="Précédent" HorizontalAlignment="Left" Width="100" Height="30" Click="BtnPrev_Click"/>
                <Button x:Name="BtnNext" Content="Suivant" HorizontalAlignment="Right" Width="100" Height="30" Click="BtnNext_Click" 
                        Background="#007ACC" Foreground="White" FontWeight="SemiBold"/>
            </Grid>
        </Border>
    </Grid>
</Window>