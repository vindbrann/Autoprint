@page "/marques"
@using Autoprint.Shared
@inject HttpClient Http

<PageTitle>Gestion des Marques</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🏷️ Gestion des Marques</h3>
    <AuthorizeView Policy="BRAND_WRITE">
        <Authorized>
            <button class="btn btn-success" @onclick="OuvrirAjout">
                <i class="bi bi-plus-circle"></i> Nouvelle Marque
            </button>
		</Authorized>
	</AuthorizeView>

</div>

@if (messageErreur != null)
{
    <div class="alert alert-danger">@messageErreur</div>
}
else if (marques == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in marques)
            {
                <tr>
                    <td>@m.Nom</td>
                    <td>
                        <AuthorizeView Policy="BRAND_WRITE">
                            <Authorized>
                                <button class="btn btn-sm btn-primary" @onclick="() => OuvrirEdition(m)">
                                    <i class="bi bi-pencil"></i> Modifier
                                </button>
                            </Authorized>
                            <NotAuthorized>
                                <button class="btn btn-sm btn-secondary" disabled title="Droit de modification requis">
                                    <i class="bi bi-pencil"></i> Modifier
                                </button>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<MarqueModal Show="afficherModal"
             Model="marqueEnCours"
             OnCancel="FermerModal"
             OnSave="Sauvegarder"
             OnDelete="Supprimer" />

@code {
    private List<Marque>? marques;
    private Marque marqueEnCours = new();
    private bool afficherModal = false;
    private string? messageErreur;

    protected override async Task OnInitializedAsync()
    {
        await ChargerListe();
    }

    private async Task ChargerListe()
    {
        try
        {
            marques = await Http.GetFromJsonAsync<List<Marque>>("api/Marques");
        }
        catch (Exception ex)
        {
            messageErreur = "Erreur : " + ex.Message;
        }
    }

    private void OuvrirAjout()
    {
        marqueEnCours = new Marque();
        afficherModal = true;
    }

    private void OuvrirEdition(Marque m)
    {
        // Copie pour édition isolée
        marqueEnCours = new Marque
        {
            Id = m.Id,
            Nom = m.Nom
        };
        afficherModal = true;
    }

    private void FermerModal() => afficherModal = false;

    private async Task Sauvegarder()
    {
        if (marqueEnCours.Id == 0)
            await Http.PostAsJsonAsync("api/Marques", marqueEnCours);
        else
            await Http.PutAsJsonAsync($"api/Marques/{marqueEnCours.Id}", marqueEnCours);

        afficherModal = false;
        await ChargerListe();
    }

    private async Task Supprimer()
    {
        if (marqueEnCours.Id > 0)
        {
            await Http.DeleteAsync($"api/Marques/{marqueEnCours.Id}");
            afficherModal = false;
            await ChargerListe();
        }
    }
}