@using Autoprint.Shared

@if (Show)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal fade show d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(Model.Id == 0 ? "➕ Nouvelle Marque" : "✏️ Modifier Marque")
                    </h5>
                    <button type="button" class="btn-close" @onclick="OnCancel"></button>
                </div>

                <div class="modal-body">
                    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Nom de la Marque</label>
                            <InputText class="form-control" @bind-Value="Model.Nom" placeholder="Ex: HP, Canon..." />
                        </div>

                        <button type="submit" style="display:none" id="submitMarqueBtn"></button>
                    </EditForm>
                </div>

                <div class="modal-footer justify-content-between">
                    @if (Model.Id != 0)
                    {
                        <button type="button" class="btn btn-danger" @onclick="HandleDelete">Supprimer</button>
                    }
                    else
                    {
                        <div></div>
                    }

                    <div>
                        <button type="button" class="btn btn-secondary" @onclick="OnCancel">Annuler</button>
                        <label for="submitMarqueBtn" class="btn btn-primary">💾 Enregistrer</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Marque Model { get; set; } = new();

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnSave.InvokeAsync();
    }

    private async Task HandleDelete()
    {
        await OnDelete.InvokeAsync();
    }
}