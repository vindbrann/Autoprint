@page "/imprimantes"
@using Autoprint.Shared
@using Autoprint.Shared.Enums
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

<PageTitle>Gestion des Imprimantes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🖨️ Parc d'Imprimantes</h3>
    <AuthorizeView Policy="PRINTER_WRITE">
        <Authorized Context="authContext">
            <button class="btn btn-success" @onclick="OuvrirAjout">
                <i class="bi bi-plus-circle"></i> Ajouter une imprimante
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (messageErreur != null)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @messageErreur
    </div>
}
else if (imprimantes == null)
{
    <div class="d-flex align-items-center">
        <div class="spinner-border text-primary me-2" role="status"></div>
        <span>Chargement du parc...</span>
    </div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th class="text-center" style="width: 50px;" title="Statut de synchronisation"><i class="bi bi-activity"></i></th>
                <th>Nom</th>
                <th>Code</th>
                <th>Modèle</th>
                <th>IP</th>
                <th>Lieu</th>
                <th>Partage</th>
                <th style="width: 120px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var imp in imprimantes)
            {
                <tr>
                    @* COLONNE STATUT (NOUVEAU) *@
                    <td class="text-center fs-5">
                        @switch (imp.Status)
                        {
                            case PrinterStatus.Synchronized:
                                <i class="bi bi-check-circle-fill text-success" title="Synchronisé"></i>
                                break;
                            case PrinterStatus.ImportedNeedsFix:
                                <i class="bi bi-exclamation-diamond-fill text-danger" title="Données incomplètes (Modèle/Lieu à définir)"></i>
                                break;
                            case PrinterStatus.PendingCreation:
                                <i class="bi bi-plus-circle-fill text-info" title="En attente de création sur Windows"></i>
                                break;
                            case PrinterStatus.PendingUpdate:
                                <i class="bi bi-pencil-fill text-warning" title="Modifications en attente de synchronisation"></i>
                                break;
                            default:
                                <i class="bi bi-question-circle text-muted"></i>
                                break;
                        }
                    </td>

                    <td><strong>@imp.NomAffiche</strong></td>
                    <td>
                        @if (!string.IsNullOrEmpty(imp.Code))
                        {
                            <span class="badge bg-light text-dark border">@imp.Code</span>
                        }
                    </td>
                    <td>
                        @if (imp.Modele != null)
                        {
                            if (imp.Modele.Nom == "GÉNÉRIQUE" || imp.Modele.Nom == "NON DÉFINI")
                            {
                                <span class="badge bg-danger">@imp.Modele.Nom</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">@imp.Modele.Nom</span>
                            }
                        }
                    </td>
                    <td><code>@imp.AdresseIp</code></td>
                    <td>
                        @if (imp.Emplacement != null)
                        {
                            if (imp.Emplacement.Nom == "NON DÉFINI")
                            {
                                <span class="badge bg-danger">@imp.Emplacement.Nom</span>
                            }
                            else
                            {
                                <span class="badge bg-info text-dark">@imp.Emplacement.Nom</span>
                            }
                        }
                    </td>
                    <td>
                        @if (imp.EstPartagee)
                        {
                            <span class="badge bg-success">Oui (@imp.NomPartage)</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Non</span>
                        }
                    </td>
                    <td>
                        <AuthorizeView Policy="PRINTER_WRITE">
                            <Authorized Context="authContext">
                                <button class="btn btn-sm btn-primary" @onclick="() => OuvrirEdition(imp)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<ImprimanteModal Show="afficherModal"
                 Model="imprimanteEnCours"
                 OnCancel="FermerModal"
                 OnSave="Sauvegarder"
                 OnDelete="Supprimer" />

@code {
    private List<Imprimante>? imprimantes;
    private Imprimante imprimanteEnCours = new();
    private bool afficherModal = false;
    private string? messageErreur;

    private bool CanReadPrinters { get; set; }

    protected override async Task OnInitializedAsync()
    {
        CanReadPrinters = await AuthProvider.HasPermission("Permission", "PRINTER_READ");

        if (CanReadPrinters)
        {
            await ChargerListe();
        }
        else
        {
            messageErreur = "Vous n'avez pas l'autorisation de consulter la liste des imprimantes.";
            imprimantes = new List<Imprimante>();
        }
    }

    private async Task ChargerListe()
    {
        try
        {
            imprimantes = await Http.GetFromJsonAsync<List<Imprimante>>("api/Imprimantes");
        }
        catch (Exception ex)
        {
            messageErreur = "Erreur chargement : " + ex.Message;
        }
    }

    private void OuvrirAjout()
    {
        imprimanteEnCours = new Imprimante { ModeleId = 0, EmplacementId = 0 };
        afficherModal = true;
    }

    private void OuvrirEdition(Imprimante imp)
    {
        // Copie de l'objet pour édition
        imprimanteEnCours = new Imprimante
        {
            Id = imp.Id,
            NomAffiche = imp.NomAffiche,
            Code = imp.Code,
            AdresseIp = imp.AdresseIp,
            Localisation = imp.Localisation,
            EstPartagee = imp.EstPartagee,
            NomPartage = imp.NomPartage,
            Commentaire = imp.Commentaire,
            ModeleId = imp.ModeleId,
            EmplacementId = imp.EmplacementId,
            Status = imp.Status // On garde le statut actuel
        };
        afficherModal = true;
    }

    private void FermerModal() => afficherModal = false;

    private async Task Sauvegarder()
    {
        // Logique de changement d'état automatique
        // Si l'imprimante était "A corriger" et qu'on a mis un vrai modèle/lieu, elle passe en "Mise à jour"
        if (imprimanteEnCours.Status == PrinterStatus.ImportedNeedsFix
            && imprimanteEnCours.ModeleId > 1
            && imprimanteEnCours.EmplacementId > 1)
        {
            imprimanteEnCours.Status = PrinterStatus.PendingUpdate;
        }

        if (imprimanteEnCours.Id == 0)
        {
            await Http.PostAsJsonAsync("api/Imprimantes", imprimanteEnCours);
        }
        else
        {
            await Http.PutAsJsonAsync($"api/Imprimantes/{imprimanteEnCours.Id}", imprimanteEnCours);
        }

        afficherModal = false;
        await ChargerListe();
    }

    private async Task Supprimer()
    {
        if (imprimanteEnCours.Id > 0)
        {
            await Http.DeleteAsync($"api/Imprimantes/{imprimanteEnCours.Id}");
            afficherModal = false;
            await ChargerListe();
        }
    }
}