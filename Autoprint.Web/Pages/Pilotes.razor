@page "/pilotes"
@using Autoprint.Shared
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

<PageTitle>Gestion des Pilotes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>💾 Bibliothèque des Pilotes</h3>
    <AuthorizeView Policy="DRIVER_WRITE">
        <Authorized Context="authContext">
            <button class="btn btn-success" @onclick="OuvrirAjout">
                <i class="bi bi-plus-circle"></i> Ajouter manuellement
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (messageErreur != null)
{
    <div class="alert alert-warning">@messageErreur</div>
}
else if (pilotes == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nom du Pilote</th>
                <th>Version</th>
                <th style="width: 100px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in pilotes)
            {
                <tr>
                    <td>@p.Nom</td>
                    <td>@p.Version</td>
                    <td>
                        <AuthorizeView Policy="DRIVER_WRITE">
                            <Authorized Context="authContext">
                                <button class="btn btn-sm btn-primary" @onclick="() => OuvrirEdition(p)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                            </Authorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<PiloteModal Show="afficherModal"
             Model="piloteEnCours"
             OnCancel="FermerModal"
             OnSave="Sauvegarder"
             OnDelete="Supprimer" />

@code {
    private List<Pilote>? pilotes;
    private Pilote piloteEnCours = new();
    private bool afficherModal = false;
    private string? messageErreur;
    private bool CanReadDrivers;

    protected override async Task OnInitializedAsync()
    {
        CanReadDrivers = await AuthProvider.HasPermission("Permission", "DRIVER_READ");
        if (CanReadDrivers)
        {
            await ChargerListe();
        }
        else
        {
            messageErreur = "Accès non autorisé aux pilotes.";
            pilotes = new List<Pilote>();
        }
    }

    private async Task ChargerListe()
    {
        try
        {
            pilotes = await Http.GetFromJsonAsync<List<Pilote>>("api/Pilotes");
        }
        catch (Exception ex)
        {
            messageErreur = "Erreur : " + ex.Message;
        }
    }

    private void OuvrirAjout()
    {
        piloteEnCours = new Pilote();
        afficherModal = true;
    }

    private void OuvrirEdition(Pilote p)
    {
        piloteEnCours = new Pilote
        {
            Id = p.Id,
            Nom = p.Nom,
            Version = p.Version
        };
        afficherModal = true;
    }

    private void FermerModal() => afficherModal = false;

    private async Task Sauvegarder()
    {
        if (piloteEnCours.Id == 0)
            await Http.PostAsJsonAsync("api/Pilotes", piloteEnCours);
        else
            await Http.PutAsJsonAsync($"api/Pilotes/{piloteEnCours.Id}", piloteEnCours);

        afficherModal = false;
        await ChargerListe();
    }

    private async Task Supprimer()
    {
        if (piloteEnCours.Id > 0)
        {
            await Http.DeleteAsync($"api/Pilotes/{piloteEnCours.Id}");
            afficherModal = false;
            await ChargerListe();
        }
    }
}