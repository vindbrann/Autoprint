@page "/pilotes"
@using Autoprint.Shared
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

<PageTitle>Gestion des Pilotes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3>💾 Bibliothèque des Pilotes</h3>
        <p class="text-muted mb-0">Inventaire des pilotes détectés sur le serveur d'impression.</p>
    </div>

    <AuthorizeView Policy="DRIVER_SCAN">
        <Authorized Context="authContext">
            <button class="btn btn-primary" @onclick="() => afficherScanModal = true">
                <i class="bi bi-hdd-network me-2"></i> Scanner le Serveur
            </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (messageErreur != null)
{
    <div class="alert alert-warning">@messageErreur</div>
}
else if (pilotes == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <div class="card shadow-sm">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Nom du Pilote</th>
                    <th>Version</th>
                    <th class="text-end">Dernière Maj</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in pilotes)
                {
                    <tr>
                        <td class="fw-bold">@p.Nom</td>
                        <td><span class="badge bg-secondary font-monospace">@p.Version</span></td>
                        <td class="text-end text-muted small">@p.DateModification.ToShortDateString()</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="mt-2 text-muted small text-end">
        Total : @pilotes.Count pilotes répertoriés.
    </div>
}

@* MODALE DE SCAN *@
<ScanDriversModal Show="afficherScanModal" OnCancel="() => afficherScanModal = false" />

@code {
    private List<Pilote>? pilotes;
    private bool afficherScanModal = false;
    private string? messageErreur;
    private bool CanReadDrivers;

    protected override async Task OnInitializedAsync()
    {
        CanReadDrivers = await AuthProvider.HasPermission("Permission", "DRIVER_READ");
        if (CanReadDrivers)
        {
            await ChargerListe();
        }
        else
        {
            messageErreur = "Accès non autorisé aux pilotes.";
            pilotes = new List<Pilote>();
        }
    }

    private async Task ChargerListe()
    {
        try
        {
            pilotes = await Http.GetFromJsonAsync<List<Pilote>>("api/Pilotes");
        }
        catch (Exception ex)
        {
            messageErreur = "Erreur : " + ex.Message;
        }
    }
}