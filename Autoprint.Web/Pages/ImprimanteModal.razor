@using Autoprint.Shared
@using System.Text.Json
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(Model.Id == 0 ? "➕ Nouvelle Imprimante" : "✏️ Modifier Imprimante")</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@Model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        @* --- NOM ET CODE --- *@
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label class="form-label">
                                    Nom affiché
                                    @if (namingEnabled)
                                    {
                                        <span class="badge bg-info ms-2"><i class="oi oi-cog"></i> Auto</span>
                                    }
                                </label>
                                <div class="input-group">
                                    <InputText class="form-control" @bind-Value="Model.NomAffiche" disabled="@namingEnabled" placeholder="Ex: IMP_ACCUEIL" />
                                    @if (namingEnabled)
                                        {
                                            @* Bouton de régénération manuelle *@
                                            <button class="btn btn-outline-secondary" type="button"
                                                    @onclick="ForcerRefreshNom"
                                                    title="Recalculer le nom automatique (Forcer la mise à jour)">

                                                @* Icône double flèche circulaire *@
                                                <i class="bi bi-arrow-clockwise"></i>
                                            </button>
                                        }
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">Code Inventaire</label>
                                <InputText class="form-control" @bind-Value="Model.Code" @onblur="GenerateNameIfEnabled" placeholder="Ex: P001" />
                            </div>
                        </div>

                        @* --- IP ET LOCALISATION --- *@
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Adresse IP</label>
                                <InputText class="form-control" @bind-Value="Model.AdresseIp" @onblur="GenerateNameIfEnabled" placeholder="192.168.x.x" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Localisation physique</label>
                                <InputText class="form-control" @bind-Value="Model.Localisation" placeholder="Ex: Bureau 204" />
                            </div>
                        </div>

                        @* --- SÉLECTION EMPLACEMENT (SÉCURISÉ) --- *@
                        <div class="mb-3">
                            <label class="form-label">Emplacement (Lieu)</label>
                            <InputSelect class="form-select"
                                         Value="@Model.EmplacementId"
                                         ValueChanged="@((int id) => OnLieuChanged(id))"
                                         ValueExpression="@(() => Model.EmplacementId)"
                                         disabled="@(!CanReadEmplacements)">
                                <option value="0">-- Choisir un emplacement --</option>
                                @if (listeEmplacements != null)
                                {
                                    @foreach (var lieu in listeEmplacements)
                                    {
                                        <option value="@lieu.Id">@lieu.Nom</option>
                                    }
                                }
                            </InputSelect>
                            @if (!CanReadEmplacements)
                            {
                                <div class="form-text text-danger">
                                    <i class="oi oi-lock-locked"></i> Vous n'avez pas l'autorisation de voir les emplacements.
                                </div>
                            }
                        </div>

                        @* --- CONFIGURATION MATÉRIELLE (MARQUE / MODÈLE) --- *@
                        <div class="card p-3 mb-3 border-primary bg-light bg-opacity-10">
                            <h6 class="text-primary">Configuration Matérielle</h6>
                            <div class="row">
                                @* MARQUE (Filtre UI seulement) *@
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">1. Choisir la Marque</label>
                                    <select class="form-select" @onchange="OnMarqueChange" value="@selectedMarqueId" disabled="@(!CanReadMarques)">
                                        <option value="0">-- Sélectionner une marque --</option>
                                        @if (listeMarques != null)
                                        {
                                            @foreach (var marque in listeMarques)
                                            {
                                                <option value="@marque.Id">@marque.Nom</option>
                                            }
                                        }
                                    </select>
                                    @if (!CanReadMarques)
                                    {
                                        <div class="form-text text-danger">
                                            <i class="oi oi-lock-locked"></i> Vous n'avez pas l'autorisation de voir les marques.
                                        </div>
                                    }
                                </div>

                                @* MODÈLE (Lié à l'imprimante) *@
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">2. Choisir le Modèle</label>
                                    <InputSelect class="form-select"
                                                 Value="@Model.ModeleId"
                                                 ValueChanged="@((int id) => OnModeleChange(id))"
                                                 ValueExpression="@(() => Model.ModeleId)"
                                                 disabled="@(selectedMarqueId == 0 || !CanReadModeles)">
                                        <option value="0">-- Sélectionner un modèle --</option>
                                        @if (listeModelesFiltres != null)
                                        {
                                            @foreach (var modele in listeModelesFiltres)
                                            {
                                                <option value="@modele.Id">@modele.Nom</option>
                                            }
                                        }
                                    </InputSelect>
                                    @if (!CanReadModeles)
                                    {
                                        <div class="form-text text-danger">
                                            <i class="oi oi-lock-locked"></i> Vous n'avez pas l'autorisation de voir les modèles.
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        @* --- PARTAGE --- *@
                        <div class="card p-3 mb-3 bg-light">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" @bind-Value="Model.EstPartagee" id="chkPartage" />
                                <label class="form-check-label" for="chkPartage">Partager sur le réseau Windows ?</label>
                            </div>
                            @if (Model.EstPartagee)
                            {
                                <div class="mt-2">
                                    <label class="form-label">Nom du partage</label>
                                    <InputText class="form-control" @bind-Value="Model.NomPartage" disabled="@(namingEnabled && namingSameShare)" />
                                </div>
                            }
                        </div>

                        <div class="modal-footer">
                            @if (Model.Id != 0)
                            {
                                @* CORRECTION ICI : Ajout de Context="authContext" *@
                                <AuthorizeView Policy="PRINTER_DELETE">
                                    <Authorized Context="authContext">
                                        <button type="button" class="btn btn-danger me-auto" @onclick="OnDelete">Supprimer</button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Annuler</button>
                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Imprimante Model { get; set; } = new();

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private List<Emplacement>? listeEmplacements;
    private List<Marque>? listeMarques;
    private List<Modele>? listeTousModeles;
    private List<Modele>? listeModelesFiltres;

    private int selectedMarqueId = 0;

    private bool namingEnabled = false;
    private bool namingSameShare = false;
    private string namingTemplate = "";

    private bool CanReadEmplacements { get; set; }
    private bool CanReadMarques { get; set; }
    private bool CanReadModeles { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Mise à jour avec les clés anglaises du Program.cs
        CanReadEmplacements = await AuthProvider.HasPermission("Permission", "LOCATION_READ");
        CanReadMarques = await AuthProvider.HasPermission("Permission", "BRAND_READ");
        CanReadModeles = await AuthProvider.HasPermission("Permission", "MODEL_READ");

        try
        {
            var tasks = new List<Task>();

            if (CanReadEmplacements)
            {
                tasks.Add(Task.Run(async () => listeEmplacements = await Http.GetFromJsonAsync<List<Emplacement>>("api/Emplacements")));
            }

            if (CanReadMarques)
            {
                tasks.Add(Task.Run(async () => listeMarques = await Http.GetFromJsonAsync<List<Marque>>("api/Marques")));
            }

            if (CanReadModeles)
            {
                tasks.Add(Task.Run(async () => listeTousModeles = await Http.GetFromJsonAsync<List<Modele>>("api/Modeles")));
            }

            tasks.Add(LoadSettingsAsync());

            if (tasks.Any()) await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur chargement données : {ex.Message}");
        }
    }

    protected override void OnParametersSet()
    {
        if (Show && listeTousModeles != null && Model.Id != 0)
        {
            var currentModele = listeTousModeles.FirstOrDefault(m => m.Id == Model.ModeleId);
            if (currentModele != null)
            {
                selectedMarqueId = currentModele.MarqueId;
                FilterModeles();
            }
        }
        else if (Show && Model.Id == 0)
        {
            selectedMarqueId = 0;
            listeModelesFiltres = new List<Modele>();
        }
    }

    private async Task LoadSettingsAsync()
    {
        try
        {
            var settings = await Http.GetFromJsonAsync<List<ServerSetting>>("api/Settings");
            if (settings != null)
            {
                namingEnabled = bool.Parse(GetVal(settings, "NamingEnabled", "false"));
                namingSameShare = bool.Parse(GetVal(settings, "NamingSameShare", "false"));
                namingTemplate = GetVal(settings, "NamingTemplate", "");
            }
        }
        catch { }
    }

    private string GetVal(List<ServerSetting> list, string key, string def) => list.FirstOrDefault(s => s.Key == key)?.Value ?? def;

    private void OnMarqueChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            selectedMarqueId = id;
            FilterModeles();
            Model.ModeleId = 0;
            GenerateNameIfEnabled();
        }
    }

    private void FilterModeles()
    {
        if (listeTousModeles != null)
        {
            listeModelesFiltres = listeTousModeles.Where(m => m.MarqueId == selectedMarqueId).ToList();
        }
    }

    private void OnModeleChange(int id)
    {
        Model.ModeleId = id;
        GenerateNameIfEnabled();
    }

    private void OnLieuChanged(int id)
    {
        Model.EmplacementId = id;
        GenerateNameIfEnabled();
    }

    private async Task ForcerRefreshNom() => await GenerateNameIfEnabled();

    private async Task GenerateNameIfEnabled()
    {
        if (!namingEnabled) return;

        var lieu = listeEmplacements?.FirstOrDefault(e => e.Id == Model.EmplacementId);
        var modele = listeTousModeles?.FirstOrDefault(m => m.Id == Model.ModeleId);
        var marque = listeMarques?.FirstOrDefault(m => m.Id == selectedMarqueId);

        var dto = new
        {
            Template = namingTemplate,
            Ip = Model.AdresseIp ?? "",
            LieuNom = lieu?.Nom ?? "",
            LieuCode = lieu?.Code ?? "",
            ModeleNom = modele?.Nom ?? "",
            MarqueNom = marque?.Nom ?? "",
            ImpCode = Model.Code ?? ""
        };

        try
        {
            var response = await Http.PostAsJsonAsync("api/Naming/Preview", dto);
            if (response.IsSuccessStatusCode)
            {
                using var doc = await JsonDocument.ParseAsync(await response.Content.ReadAsStreamAsync());
                if (doc.RootElement.TryGetProperty("generatedName", out var prop))
                {
                    string val = prop.GetString() ?? "";
                    Model.NomAffiche = val;
                    if (namingSameShare) Model.NomPartage = val;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erreur Naming: " + ex.Message);
        }
    }

    private async Task HandleValidSubmit()
    {
        if (Model.EmplacementId == 0 || Model.ModeleId == 0) return;
        await OnSave.InvokeAsync();
    }
}