@using Autoprint.Shared
@using Autoprint.Shared.DTOs
@using System.Text.Json
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject IJSRuntime JS
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject Autoprint.Web.Services.NetworkScannerService ScannerService

<RadzenStack Gap="1rem" Style="height: 100%;">

    <RadzenTabs RenderMode="TabRenderMode.Client" @bind-SelectedIndex="@selectedTabIndex">
        <Tabs>
            <RadzenTabsItem Text="Serveur Windows (RPC)">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap" Class="rz-p-2">
                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="Serveur Cible" Component="Host" Style="font-size: 0.8rem; font-weight: bold;" />
                        <RadzenTextBox Name="Host" @bind-Value="@request.TargetHost" Placeholder="localhost ou IP" Style="width: 200px;" />
                    </RadzenStack>

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="Utilisateur (Admin)" Component="User" Style="font-size: 0.8rem; font-weight: bold;" />
                        <RadzenTextBox Name="User" @bind-Value="@request.Username" Placeholder="DOMAIN\Admin" Style="width: 150px;" />
                    </RadzenStack>

                    <RadzenStack Gap="0.2rem">
                        <RadzenLabel Text="Mot de passe" Component="Pwd" Style="font-size: 0.8rem; font-weight: bold;" />
                        <RadzenPassword Name="Pwd" @bind-Value="@request.Password" Style="width: 150px;" />
                    </RadzenStack>

                    <RadzenButton Text="Scanner le Serveur" Icon="dns" Click="@LancerScanWindows" IsBusy="@scanEnCours" ButtonStyle="ButtonStyle.Primary" />
                </RadzenStack>
            </RadzenTabsItem>

            <RadzenTabsItem Text="Scan Réseau (Port 9100 + SNMP)">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.End" Gap="1rem" Wrap="FlexWrap.Wrap" Class="rz-p-2">
                    <RadzenStack Gap="0.2rem" Style="flex: 1;">
                        <RadzenLabel Text="Sélectionner un Lieu à scanner" Component="LieuScan" Style="font-size: 0.8rem; font-weight: bold;" />
                        <RadzenDropDown Name="LieuScan" Data="@listeLieux" @bind-Value="scanLieuId"
                                        TextProperty="Nom" ValueProperty="Id"
                                        Placeholder="Choisir un emplacement..."
                                        AllowFiltering="true" FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
                                        Style="width: 100%;">
                            <Template Context="lieu">
                                @((lieu as Emplacement).Nom)
                                @{
                                    var l = lieu as Emplacement;
                                    if (l.Networks != null && l.Networks.Any())
                                    {
                                        var mainNet = l.Networks.First();
                                        <span style="color:var(--rz-text-tertiary-color); font-size:0.8em; margin-left:5px;">
                                            Scan : @mainNet.CidrIpv4
                                            @(l.Networks.Count > 1 ? $" (+{l.Networks.Count - 1} autres)" : "")
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="color:var(--rz-warning); font-size:0.8em; margin-left:5px;">(Aucun réseau)</span>
                                    }
                                }
                            </Template>
                        </RadzenDropDown>
                    </RadzenStack>

                    <RadzenButton Text="Scanner le Réseau" Icon="radar" Click="@LancerScanReseau" IsBusy="@scanEnCours" ButtonStyle="ButtonStyle.Secondary" Disabled="@(scanLieuId == 0)" />
                </RadzenStack>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>

    @if (resultats != null)
    {
        if (resultats.Any())
        {
            <div style="flex: 1; overflow: hidden; border: 1px solid var(--rz-border-color); border-radius: var(--rz-border-radius);">
                <RadzenDataGrid Data="@resultats" TItem="ImportPrinterViewModel"
                                AllowFiltering="true" FilterMode="FilterMode.Simple"
                                AllowSorting="true" AllowPaging="false"
                                Style="height: 100%;">
                    <Columns>

                        <RadzenDataGridColumn TItem="ImportPrinterViewModel" Width="60px" TextAlign="TextAlign.Center" Sortable="false" Filterable="false">
                            <HeaderTemplate>
                                <RadzenIcon Icon="save_alt" />
                            </HeaderTemplate>
                            <Template Context="p">
                                @if (p.ExistsInDb)
                                {
                                    <RadzenIcon Icon="check_circle" Style="color: var(--rz-success);" Tooltip="Déjà gérée" />
                                }
                                else
                                {
                                    <RadzenCheckBox @bind-Value="p.SelectedForImport" TriState="false" />
                                }
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="ImportPrinterViewModel" Property="Name" Title="Nom & Modèle" Width="250px">
                            <Template Context="p">
                                <div style="line-height: 1.2;">
                                    @if (!string.IsNullOrEmpty(p.Name) && p.Name != p.PortName)
                                    {
                                        <strong>@p.Name</strong>
                                    }
                                    else
                                    {
                                        <span style="font-style: italic; color: var(--rz-text-disabled-color); font-size: 0.9em;">
                                            <RadzenIcon Icon="dns" Style="font-size: 0.8rem; margin-right: 2px; vertical-align: middle;" />
                                            Nom DNS introuvable
                                        </span>
                                    }

                                    @if (p.IsShared)
                                    {
                                        <br />
                                        <RadzenBadge BadgeStyle="BadgeStyle.Warning" Text="@p.ShareName" Icon="share" Style="margin-top: 4px;" />
                                    }

                                    @if (!string.IsNullOrEmpty(p.DriverName) && p.DriverName != "Inconnu (SNMP Muet)")
                                    {
                                        <div style="font-size: 0.75rem; color: #1e88e5; margin-top: 4px;">
                                            <RadzenIcon Icon="print" Style="font-size: 0.7rem; margin-right: 3px; vertical-align: middle;" />
                                            @p.DriverName
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="font-size: 0.75rem; color: #ff9800; margin-top: 4px;">
                                            <RadzenIcon Icon="question_mark" Style="font-size: 0.7rem; margin-right: 3px; vertical-align: middle;" />
                                            Modèle inconnu (SNMP)
                                        </div>
                                    }
                                </div>
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="ImportPrinterViewModel" Property="PortName" Title="Adresse IP" Width="140px">
                            <Template Context="p">
                                @if (p.ExistsInDb)
                                {
                                    <span style="font-family: monospace; color: var(--rz-text-disabled-color);">@p.PortName</span>
                                }
                                else
                                {
                                    <RadzenTextBox @bind-Value="p.PortName" Change="@(args => OnIpChanged(p, args))"
                                                   Style="width: 100%; font-family: monospace;"
                                                   Class="@(p.IpMismatchWarning ? "rz-border-warning" : "")" />
                                    @if (p.IpMismatchWarning)
                                    {
                                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-warning);" TagName="TagName.Div">
                                            <RadzenIcon Icon="warning" Style="font-size: 0.8rem" /> Hors zone
                                        </RadzenText>
                                    }
                                }
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="ImportPrinterViewModel" Title="Modèle (Requis)" Width="200px">
                            <Template Context="p">
                                @if (!p.ExistsInDb)
                                {
                                    <RadzenDropDown @bind-Value="p.SelectedModeleId" Data="@listeModeles"
                                                    TextProperty="Nom" ValueProperty="Id"
                                                    Placeholder="Choisir..." Style="width: 100%;"
                                                    AllowFiltering="true" />
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>

                        <RadzenDataGridColumn TItem="ImportPrinterViewModel" Title="Lieu (Requis)" Width="200px">
                            <Template Context="p">
                                @if (!p.ExistsInDb)
                                {
                                    <RadzenDropDown @bind-Value="p.SelectedLieuId" Data="@listeLieux"
                                                    TextProperty="Nom" ValueProperty="Id"
                                                    Placeholder="Choisir..." Style="width: 100%;"
                                                    Change="@(args => OnLieuChanged(p, args))"
                                                    AllowFiltering="true" />
                                }
                                else
                                {
                                    <span style="color: var(--rz-text-disabled-color);">Déjà assigné</span>
                                }
                            </Template>
                        </RadzenDataGridColumn>

                    </Columns>
                </RadzenDataGrid>
            </div>
        }
        else if (!scanEnCours)
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter" Class="rz-mt-4">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                    <RadzenIcon Icon="info" />
                    <span>Aucune imprimante trouvée avec les critères actuels.</span>
                </RadzenStack>
            </RadzenAlert>
        }
    }

    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Class="rz-mt-2">
        <RadzenButton Text="Fermer" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />

        @if (resultats != null && resultats.Any(p => p.SelectedForImport))
        {
            <RadzenButton Text="@($"Importer la sélection ({resultats.Count(p => p.SelectedForImport)})")"
                          Icon="save_alt" ButtonStyle="ButtonStyle.Success" Click="@ImporterSelection" />
        }
    </RadzenStack>

</RadzenStack>

@code {

    private int selectedTabIndex = 0;
    private bool scanEnCours = false;
    private int scanLieuId = 0;
    private bool _defaultDirectMode = false;
    private bool _forceShare = false;

    private RemoteScanRequestDto request = new() { TargetHost = "localhost" };
    private List<ImportPrinterViewModel>? resultats;
    private List<Modele> listeModeles = new();
    private List<Emplacement> listeLieux = new();

    public class ImportPrinterViewModel : DiscoveredPrinterDto
    {
        public bool SelectedForImport { get; set; }
        public int SelectedModeleId { get; set; }
        public int SelectedLieuId { get; set; }
        public bool IpMismatchWarning { get; set; } = false;
        public string IpMismatchMessage { get; set; } = "";
        public bool IsDirectPrintingEnabled { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Http.GetFromJsonAsync<List<Modele>>("api/Modeles");
            var t2 = Http.GetFromJsonAsync<List<Emplacement>>("api/Emplacements");
            var t3 = Http.GetFromJsonAsync<List<ServerSetting>>("api/Settings");
            await Task.WhenAll(t1, t2);

            listeModeles = t1.Result ?? new();
            listeLieux = t2.Result ?? new();
            var settings = t3.Result ?? new();
            _defaultDirectMode = bool.Parse(settings.FirstOrDefault(s => s.Key == "Printer_DefaultDirectModeEnabled")?.Value ?? "false");
            _forceShare = bool.Parse(settings.FirstOrDefault(s => s.Key == "NamingSameShare")?.Value ?? "false");
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur Init", ex.Message);
        }
    }

    private async Task LancerScanWindows()
    {
        scanEnCours = true;
        resultats = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/Import/Scan/Printers", request);
            if (response.IsSuccessStatusCode)
            {
                resultats = await response.Content.ReadFromJsonAsync<List<ImportPrinterViewModel>>();
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur WMI", await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur Technique", ex.Message);
        }
        finally
        {
            scanEnCours = false;
        }
    }

    private async Task LancerScanReseau()
    {
        if (scanLieuId == 0) return;
        var lieu = listeLieux.FirstOrDefault(l => l.Id == scanLieuId);

        var primaryNetwork = lieu?.Networks?.FirstOrDefault();

        if (lieu == null || primaryNetwork == null || string.IsNullOrEmpty(primaryNetwork.CidrIpv4))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Impossible de scanner", "Ce lieu n'a aucun réseau configuré.");
            return;
        }

        scanEnCours = true;
        resultats = new List<ImportPrinterViewModel>();

        try
        {
            var scanResults = await ScannerService.ScanNetworkForImportAsync(primaryNetwork.CidrIpv4);

            resultats = scanResults.Select(r => new ImportPrinterViewModel
            {
                PortName = r.IpAddress,
                Name = string.IsNullOrEmpty(r.Hostname) ? r.IpAddress : r.Hostname,
                DriverName = r.SnmpModel,
                ExistsInDb = r.IsRegistered,
                SelectedLieuId = scanLieuId,
                SelectedForImport = !r.IsRegistered,
                SelectedModeleId = FindModelIdBySnmp(r.SnmpModel),
                IsShared = _forceShare,
                IsDirectPrintingEnabled = _defaultDirectMode
            }).ToList();

            if (resultats.Any())
            {
                NotificationService.Notify(NotificationSeverity.Success, "Scan terminé", $"{resultats.Count} imprimantes trouvées sur {primaryNetwork.CidrIpv4}.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur Scan", ex.Message);
        }
        finally
        {
            scanEnCours = false;
        }
    }

    private int FindModelIdBySnmp(string snmpModel)
    {
        if (string.IsNullOrWhiteSpace(snmpModel) || !listeModeles.Any()) return 0;
        var match = listeModeles.FirstOrDefault(m => snmpModel.Contains(m.Nom, StringComparison.OrdinalIgnoreCase));
        return match?.Id ?? 0;
    }

    private void OnLieuChanged(ImportPrinterViewModel p, object? value)
    {
        if (value is int val)
        {
            p.SelectedLieuId = val;
            CheckIpConsistency(p);
        }
    }

    private void OnIpChanged(ImportPrinterViewModel p, string value)
    {
        p.PortName = value;
        CheckIpConsistency(p);
    }

    private void CheckIpConsistency(ImportPrinterViewModel p)
    {

        p.IpMismatchWarning = false;
        if (p.SelectedLieuId == 0 || string.IsNullOrEmpty(p.PortName)) return;

        var lieu = listeLieux.FirstOrDefault(l => l.Id == p.SelectedLieuId);
        if (lieu == null || lieu.Networks == null) return;

        bool matchFound = false;

        foreach (var network in lieu.Networks)
        {
            if (string.IsNullOrEmpty(network.CidrIpv4) || !network.CidrIpv4.Contains("/")) continue;

            try
            {
                var parts = network.CidrIpv4.Split('/');
                var ipParts = parts[0].Split('.');
                if (int.TryParse(parts[1], out int cidr))
                {
                    string prefixToCheck = "";
                    if (cidr >= 24) prefixToCheck = $"{ipParts[0]}.{ipParts[1]}.{ipParts[2]}.";
                    else if (cidr >= 16) prefixToCheck = $"{ipParts[0]}.{ipParts[1]}.";

                    if (!string.IsNullOrEmpty(prefixToCheck) && p.PortName.StartsWith(prefixToCheck))
                    {
                        matchFound = true;
                        break;
                    }
                }
            }
            catch { }
        }

        if (!matchFound)
        {
            p.IpMismatchWarning = true;
        }
    }

    private async Task ImporterSelection()
    {
        if (resultats == null) return;

        var selection = resultats.Where(p => p.SelectedForImport).Select(p => new
        {
            Name = p.Name,
            PortName = p.PortName,
            ShareName = p.ShareName,
            IsShared = p.IsShared,
            SelectedModeleId = p.SelectedModeleId,
            SelectedLieuId = p.SelectedLieuId,
            IsDirectPrintingEnabled = p.IsDirectPrintingEnabled
        }).ToList();

        if (!selection.Any()) return;

        try
        {
            var res = await Http.PostAsJsonAsync("api/Import/Import/Printers", selection);
            if (res.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Succès", "Import terminé !");
                DialogService.Close(true);
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erreur Import", await res.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur Technique", ex.Message);
        }
    }
}