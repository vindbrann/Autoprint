@using Autoprint.Shared
@using Autoprint.Shared.DTOs
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-printer me-2"></i> Scan des Imprimantes (Réseau Windows)</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OnCancel"></button>
                </div>

                <div class="modal-body">
                    @* --- BARRE DE RECHERCHE --- *@
                    <div class="card bg-light mb-3 border-0">
                        <div class="card-body py-2">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-4">
                                    <label class="form-label small fw-bold">Serveur Cible</label>
                                    <input class="form-control form-control-sm" @bind="request.TargetHost" placeholder="localhost ou IP" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold">Utilisateur (Admin)</label>
                                    <input class="form-control form-control-sm" @bind="request.Username" placeholder="DOMAIN\Admin" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-bold">Mot de passe</label>
                                    <input type="password" class="form-control form-control-sm" @bind="request.Password" />
                                </div>
                                <div class="col-md-2">
                                    <button class="btn btn-sm btn-primary w-100" @onclick="LancerScan" disabled="@scanEnCours">
                                        @if (scanEnCours)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-search"></i>
                                        }
                                        Scanner
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* --- RÉSULTATS --- *@
                    @if (resultats != null && resultats.Any())
                    {
                        <div class="table-responsive border rounded" style="max-height: 60vh;">
                            <table class="table table-bordered table-hover mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="text-center" style="width: 50px">Import</th>
                                        <th>Imprimante (Windows)</th>
                                        <th>Port / IP</th>
                                        <th>Modèle (Requis)</th>
                                        <th>Lieu (Requis)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in resultats)
                                    {
                                        <tr class="@(p.ExistsInDb ? "table-success bg-opacity-25" : "")">
                                            @* CHECKBOX IMPORT *@
                                            <td class="text-center align-middle">
                                                @if (p.ExistsInDb)
                                                {
                                                    <i class="bi bi-check-circle-fill text-success fs-5" title="Déjà gérée"></i>
                                                }
                                                else
                                                {
                                                    <input type="checkbox" class="form-check-input" @bind="p.SelectedForImport" style="transform: scale(1.3); cursor: pointer;" />
                                                }
                                            </td>

                                            @* INFO IMPRIMANTE *@
                                            <td>
                                                <strong>@p.Name</strong>
                                                @if (p.IsShared)
                                                {
                                                    <br />
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-share"></i> @p.ShareName</span>
                                                }
                                                <div class="small text-muted fst-italic mt-1">Driver: @p.DriverName</div>
                                            </td>

                                            @* IP (AVEC VALIDATION VISUELLE) *@
                                            <td>
                                                @if (p.ExistsInDb)
                                                {
                                                    <span class="font-monospace text-muted">@p.PortName</span>
                                                }
                                                else
                                                {
                                                    <div class="input-group input-group-sm">
                                                        <input class="form-control font-monospace @(p.IpMismatchWarning ? "border-warning text-warning" : "") @(string.IsNullOrEmpty(p.PortName) ? "is-invalid" : "")"
                                                               value="@p.PortName"
                                                               @onchange="@((ChangeEventArgs e) => OnIpChanged(p, e.Value))"
                                                               placeholder="192.168.x.x"
                                                               title="@p.IpMismatchMessage" />

                                                        @if (p.IpMismatchWarning)
                                                        {
                                                            <span class="input-group-text bg-warning text-dark border-warning" title="@p.IpMismatchMessage">
                                                                <i class="bi bi-exclamation-triangle-fill"></i>
                                                            </span>
                                                        }
                                                    </div>
                                                    @if (string.IsNullOrEmpty(p.PortName))
                                                    {
                                                        <div class="text-danger small" style="font-size: 0.7rem;">IP Requise</div>
                                                    }
                                                }
                                            </td>

                                            @* MODÈLE *@
                                            <td>
                                                @if (!p.ExistsInDb)
                                                {
                                                    <select class="form-select form-select-sm" @bind="p.SelectedModeleId">
                                                        <option value="0" class="text-muted">-- Modèle --</option>
                                                        @foreach (var m in listeModeles)
                                                        {
                                                            <option value="@m.Id">@m.Nom</option>
                                                        }
                                                    </select>
                                                }
                                            </td>

                                            @* LIEU (DÉCLENCHEUR VALIDATION) *@
                                            <td>
                                                @if (!p.ExistsInDb)
                                                {
                                                    <select class="form-select form-select-sm"
                                                            value="@p.SelectedLieuId"
                                                            @onchange="@((ChangeEventArgs e) => OnLieuChanged(p, e.Value))">
                                                        <option value="0" class="text-muted">-- Lieu --</option>
                                                        @foreach (var l in listeLieux)
                                                        {
                                                            <option value="@l.Id">@l.Nom</option>
                                                        }
                                                    </select>
                                                    @if (p.SelectedLieuId > 0)
                                                    {
                                                        var lieu = listeLieux.FirstOrDefault(x => x.Id == p.SelectedLieuId);
                                                        if (lieu != null && !string.IsNullOrEmpty(lieu.CidrIpv4))
                                                        {
                                                            <div class="text-muted small fst-italic text-end">@lieu.CidrIpv4</div>
                                                        }
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Déjà assigné</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (!scanEnCours && resultats != null)
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-printer-fill fs-1 d-block mb-2"></i>
                            Aucune imprimante trouvée sur ce serveur.
                        </div>
                    }
                </div>

                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="OnCancel">Fermer</button>
                    @if (resultats != null && resultats.Any(p => p.SelectedForImport))
                    {
                        <button type="button" class="btn btn-success" @onclick="ImporterSelection">
                            <i class="bi bi-save me-2"></i> Importer (@resultats.Count(p => p.SelectedForImport))
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnImportDone { get; set; }

    private bool scanEnCours = false;
    private RemoteScanRequestDto request = new() { TargetHost = "localhost" };
    private List<ImportPrinterViewModel>? resultats;

    private List<Modele> listeModeles = new();
    private List<Emplacement> listeLieux = new();

    // ViewModel étendu pour gérer l'état visuel local
    public class ImportPrinterViewModel : DiscoveredPrinterDto
    {
        public bool SelectedForImport { get; set; }
        public int SelectedModeleId { get; set; }
        public int SelectedLieuId { get; set; }

        // Nouveaux indicateurs visuels
        public bool IpMismatchWarning { get; set; } = false;
        public string IpMismatchMessage { get; set; } = "";
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var t1 = Http.GetFromJsonAsync<List<Modele>>("api/Modeles");
            var t2 = Http.GetFromJsonAsync<List<Emplacement>>("api/Emplacements");
            await Task.WhenAll(t1, t2);

            listeModeles = t1.Result ?? new();
            listeLieux = t2.Result ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erreur chargement référentiels: " + ex.Message);
        }
    }

    private async Task LancerScan()
    {
        scanEnCours = true;
        resultats = null;
        try
        {
            var response = await Http.PostAsJsonAsync("api/Import/Scan/Printers", request);
            if (response.IsSuccessStatusCode)
            {
                resultats = await response.Content.ReadFromJsonAsync<List<ImportPrinterViewModel>>();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Erreur WMI : " + await response.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur Technique: " + ex.Message);
        }
        finally
        {
            scanEnCours = false;
        }
    }

    // --- LOGIQUE DE VALIDATION IP/LIEU ---

    private void OnLieuChanged(ImportPrinterViewModel p, object? value)
    {
        if (int.TryParse(value?.ToString(), out int lieuId))
        {
            p.SelectedLieuId = lieuId;
            CheckIpConsistency(p);
        }
    }

    private void OnIpChanged(ImportPrinterViewModel p, object? value)
    {
        p.PortName = value?.ToString() ?? "";
        CheckIpConsistency(p);
    }

    private void CheckIpConsistency(ImportPrinterViewModel p)
    {
        p.IpMismatchWarning = false;
        p.IpMismatchMessage = "";

        // On ne vérifie que si on a un lieu et une IP
        if (p.SelectedLieuId == 0 || string.IsNullOrEmpty(p.PortName)) return;

        var lieu = listeLieux.FirstOrDefault(l => l.Id == p.SelectedLieuId);
        if (lieu != null && !string.IsNullOrEmpty(lieu.CidrIpv4) && lieu.CidrIpv4.Contains("/"))
        {
            try
            {
                // Extraction simple du préfixe (ex: 192.168.10.)
                var parts = lieu.CidrIpv4.Split('/');
                var ipParts = parts[0].Split('.');

                if (parts.Length > 1 && int.TryParse(parts[1], out int cidr))
                {
                    string prefixToCheck = "";

                    if (cidr >= 24) prefixToCheck = $"{ipParts[0]}.{ipParts[1]}.{ipParts[2]}.";
                    else if (cidr >= 16) prefixToCheck = $"{ipParts[0]}.{ipParts[1]}.";
                    else if (cidr >= 8) prefixToCheck = $"{ipParts[0]}.";

                    if (!string.IsNullOrEmpty(prefixToCheck) && !p.PortName.StartsWith(prefixToCheck))
                    {
                        p.IpMismatchWarning = true;
                        p.IpMismatchMessage = $"Incohérence : L'IP {p.PortName} ne commence pas par {prefixToCheck} (Lieu : {lieu.Nom})";
                    }
                }
            }
            catch { /* Ignorer les erreurs de parsing CIDR */ }
        }
    }

    // -------------------------------------

    private async Task ImporterSelection()
    {
        if (resultats == null) return;

        var selection = resultats.Where(p => p.SelectedForImport).Select(p => new
        {
            Name = p.Name,
            PortName = p.PortName,
            ShareName = p.ShareName,
            IsShared = p.IsShared,
            SelectedModeleId = p.SelectedModeleId,
            SelectedLieuId = p.SelectedLieuId
        }).ToList();

        try
        {
            var res = await Http.PostAsJsonAsync("api/Import/Import/Printers", selection);
            if (res.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Import terminé avec succès !");
                await OnImportDone.InvokeAsync();
                resultats = null;
            }
            else
            {
                await JS.InvokeVoidAsync("alert", "Erreur Import : " + await res.Content.ReadAsStringAsync());
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur Technique : " + ex.Message);
        }
    }
}