@using Autoprint.Shared
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenTemplateForm TItem="Emplacement" Data="@lieuEdit" Submit="@OnSubmit">
    <RadzenStack Gap="1rem">

        <RadzenRow AlignItems="AlignItems.End" RowGap="0.5rem">
            <RadzenColumn Size="8">
                <RadzenLabel Text="Nom du Lieu" Component="Nom" />
                <RadzenTextBox Name="Nom" @bind-Value="@lieuEdit.Nom" Style="width: 100%;" Placeholder="Ex: Siège Social" />
                <RadzenRequiredValidator Component="Nom" Text="Le nom est requis" Popup="true" />
            </RadzenColumn>
            <RadzenColumn Size="4">
                <RadzenLabel Text="Code" Component="Code" />
                <RadzenTextBox Name="Code" @bind-Value="@lieuEdit.Code" Style="width: 100%;" Placeholder="Ex: SIEGE" />
            </RadzenColumn>
        </RadzenRow>

        <RadzenFieldset Text="Réseau Principal">
            <RadzenRow AlignItems="AlignItems.End" RowGap="0.5rem">
                <RadzenColumn Size="12">
                    <RadzenLabel Text="CIDR Principal" Component="PrimCidr" Style="font-weight: bold;" />
                    <RadzenTextBox Name="PrimCidr" @bind-Value="@primaryCidr" Placeholder="10.x.x.x/24" Style="width: 100%;" />
                    <RadzenRegexValidator Component="PrimCidr" Text="Format IP/Masque incorrect" Pattern="^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\/(3[0-2]|[12]?[0-9]|[0-9])$" Popup="true" />
                </RadzenColumn>
            </RadzenRow>
        </RadzenFieldset>

        <RadzenFieldset Text="Réseaux Secondaires">
            <RadzenStack Gap="0.5rem">

                <RadzenCard Variant="Variant.Outlined" Class="rz-p-2" Style="background-color: var(--rz-base-100);">
                    <RadzenRow AlignItems="AlignItems.End" RowGap="0.5rem">
                        <RadzenColumn Size="5">
                            <RadzenLabel Text="CIDR Secondaire" Component="SecCidr" Style="font-size: 0.8em;" />
                            <RadzenTextBox Name="SecCidr" @bind-Value="@tempSecCidr" Placeholder="192.168.x.x/16" Style="width: 100%;" />
                        </RadzenColumn>
                        <RadzenColumn Size="5">
                            <RadzenLabel Text="Description" Component="SecDesc" Style="font-size: 0.8em;" />
                            <RadzenTextBox Name="SecDesc" @bind-Value="@tempSecDesc" Placeholder="Ex: Wifi Campus" Style="width: 100%;" />
                        </RadzenColumn>
                        <RadzenColumn Size="2">
                            <RadzenButton Icon="add" ButtonStyle="ButtonStyle.Secondary" Click="@AjouterSecondaire" ToolTip="Ajouter ce réseau secondaire" />
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

                <RadzenDataGrid @ref="networksGrid" Data="@secondaryNetworks" TItem="EmplacementNetwork" Density="Density.Compact" AllowSorting="false" Class="rz-mt-2" Style="height: 150px; border: 1px solid var(--rz-border-color);">
                    <Columns>
                        <RadzenDataGridColumn TItem="EmplacementNetwork" Property="CidrIpv4" Title="Réseau" Width="140px">
                            <Template Context="n">
                                <span style="color: var(--rz-text-secondary-color);">@n.CidrIpv4</span>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="EmplacementNetwork" Property="Description" Title="Description" />
                        <RadzenDataGridColumn TItem="EmplacementNetwork" Context="n" Filterable="false" Sortable="false" TextAlign="TextAlign.Center" Width="60px">
                            <Template Context="n">
                                <RadzenButton Icon="delete" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Click="@(() => SupprimerSecondaire(n))" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>

            </RadzenStack>
        </RadzenFieldset>

        <RadzenCard Variant="Variant.Flat" Class="rz-p-3" Style="background-color: var(--rz-base-200);">
            <RadzenStack Orientation="Orientation.Vertical" Gap="0.5rem">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenCheckBox @bind-Value="IsActive" Name="StatusCheck" TValue="bool" />
                    <RadzenLabel Text="Site Actif (Opérationnel)" Component="StatusCheck" Style="cursor: pointer; font-weight: bold;" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Class="rz-mt-4">
            @if (lieuEdit.Id != 0)
            {
                <AuthorizeView Policy="LOCATION_DELETE">
                    <Authorized Context="authContext">
                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Variant="Variant.Flat" Text="Supprimer" Click="@OnDelete" />
                    </Authorized>
                </AuthorizeView>
            }
            else
            {

                <div></div>
            }

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Enregistrer" Icon="save" ButtonStyle="ButtonStyle.Primary" />
            </RadzenStack>
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public Emplacement LieuToEdit { get; set; } = new();

    private Emplacement lieuEdit = new();

    private string primaryCidr = "";
    private int primaryId = 0;
    private RadzenDataGrid<EmplacementNetwork>? networksGrid;
    private List<EmplacementNetwork> secondaryNetworks = new();

    private string tempSecCidr = "";
    private string tempSecDesc = "";

    bool IsActive
    {
        get => lieuEdit.Status == LieuStatus.Active;
        set => lieuEdit.Status = value ? LieuStatus.Active : LieuStatus.Inactive;
    }

    protected override void OnInitialized()
    {
        lieuEdit = new Emplacement
        {
            Id = LieuToEdit.Id,
            Nom = LieuToEdit.Nom,
            Code = LieuToEdit.Code,
            Status = LieuToEdit.Status,
            Networks = new List<EmplacementNetwork>()
        };

        if (LieuToEdit.Networks != null)
        {
            var mainNet = LieuToEdit.Networks.FirstOrDefault(n => n.IsPrimary);
            if (mainNet != null)
            {
                primaryCidr = mainNet.CidrIpv4;
                primaryId = mainNet.Id;
            }

            foreach (var net in LieuToEdit.Networks.Where(n => !n.IsPrimary))
            {
                secondaryNetworks.Add(new EmplacementNetwork
                {
                    Id = net.Id,
                    CidrIpv4 = net.CidrIpv4,
                    Description = net.Description,
                    IsPrimary = false,
                    EmplacementId = net.EmplacementId
                });
            }
        }
    }

    private async Task AjouterSecondaire()
    {
        if (string.IsNullOrWhiteSpace(tempSecCidr)) return;

        var regex = new System.Text.RegularExpressions.Regex(@"^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\/(3[0-2]|[12]?[0-9]|[0-9])$");
        if (!regex.IsMatch(tempSecCidr))
        {
            NotificationService.Notify(NotificationSeverity.Warning, "Format Invalide", "IP/Masque (ex: 192.168.1.0/24)");
            return;
        }

        if (secondaryNetworks.Any(n => n.CidrIpv4 == tempSecCidr) || tempSecCidr == primaryCidr)
        {
            NotificationService.Notify(NotificationSeverity.Info, "Doublon", "Réseau déjà présent.");
            return;
        }

        secondaryNetworks.Add(new EmplacementNetwork
        {
            CidrIpv4 = tempSecCidr,
            Description = string.IsNullOrWhiteSpace(tempSecDesc) ? "Réseau Secondaire" : tempSecDesc,
            IsPrimary = false
        });

        tempSecCidr = "";
        tempSecDesc = "";

        if (networksGrid != null) await networksGrid.Reload();
    }

    private async Task SupprimerSecondaire(EmplacementNetwork net)
    {
        secondaryNetworks.Remove(net);

        if (networksGrid != null) await networksGrid.Reload();
    }

    private async Task OnSubmit(Emplacement args)
    {
        try
        {
            lieuEdit.Networks.Clear();

            if (!string.IsNullOrWhiteSpace(primaryCidr))
            {
                lieuEdit.Networks.Add(new EmplacementNetwork
                {
                    Id = primaryId,
                    CidrIpv4 = primaryCidr,
                    Description = "Réseau Principal",
                    IsPrimary = true
                });
            }

            foreach (var sec in secondaryNetworks)
            {
                lieuEdit.Networks.Add(sec);
            }

            lieuEdit.Nom = lieuEdit.Nom?.Trim();
            lieuEdit.Code = lieuEdit.Code?.Trim().ToUpper();

            if (lieuEdit.Id == 0)
            {
                await Http.PostAsJsonAsync("api/Emplacements", lieuEdit);
                NotificationService.Notify(NotificationSeverity.Success, "Succès", "Lieu créé.");
            }
            else
            {
                await Http.PutAsJsonAsync($"api/Emplacements/{lieuEdit.Id}", lieuEdit);
                NotificationService.Notify(NotificationSeverity.Success, "Succès", "Lieu mis à jour.");
            }
            DialogService.Close(true);
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message);
        }
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Supprimer ce lieu ?", "Confirmer", new ConfirmOptions() { OkButtonText = "Oui", CancelButtonText = "Non" });
        if (confirm == true)
        {
            try
            {
                await Http.DeleteAsync($"api/Emplacements/{lieuEdit.Id}");
                DialogService.Close(true);
            }
            catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message); }
        }
    }
}