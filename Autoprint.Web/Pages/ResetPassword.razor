@page "/reset-password"
@layout Autoprint.Web.Layout.EmptyLayout
@using Microsoft.AspNetCore.WebUtilities
@using Autoprint.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JS

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Définir un nouveau mot de passe</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="@model" OnValidSubmit="HandleReset">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label">Nouveau mot de passe</label>
                            <InputText type="password" class="form-control" @bind-Value="model.NewPassword" />
                            <ValidationMessage For="@(() => model.NewPassword)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirmer</label>
                            <InputText type="password" class="form-control" @bind-Value="model.ConfirmPassword" />
                            <ValidationMessage For="@(() => model.ConfirmPassword)" />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Valider</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ResetPasswordDto model = new();

    protected override void OnInitialized()
    {
        // On récupère le token dans l'URL
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("token", out var token))
        {
            model.Token = token;
        }
    }

    private async Task HandleReset()
    {
        var res = await Http.PostAsJsonAsync("api/auth/reset-password", model);
        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "Mot de passe changé ! Vous pouvez vous connecter.");
            NavManager.NavigateTo("/login");
        }
        else
        {
            var msg = await res.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "Erreur : " + msg);
        }
    }
}