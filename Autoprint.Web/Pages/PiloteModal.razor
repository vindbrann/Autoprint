@using Autoprint.Shared
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(Model.Id == 0 ? "Ajouter un Pilote" : "Modifier le Pilote")</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@Model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Nom du Pilote (Windows)</label>
                            <InputText class="form-control" @bind-Value="Model.Nom" placeholder="Ex: HP Universal Printing PCL 6" />
                            <small class="text-muted">Copiez ici le nom exact tel qu'il apparaît dans le Gestionnaire d'impression Windows.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Version</label>
                            <InputText class="form-control" @bind-Value="Model.Version" placeholder="Ex: 7.1.0" />
                        </div>

                        <div class="modal-footer">
                            @if (Model.Id != 0)
                            {
                                <AuthorizeView Policy="DRIVER_DELETE">
                                    <Authorized Context="authContext">
                                        <button type="button" class="btn btn-danger me-auto" @onclick="OnDelete">Supprimer</button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Annuler</button>
                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Pilote Model { get; set; } = new();

    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnSave.InvokeAsync();
    }
}