@using Autoprint.Shared
@using Autoprint.Web.Services
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenTemplateForm TItem="Pilote" Data="@piloteEdit" Submit="@OnSubmit">
    <RadzenStack Gap="1rem">

        <div>
            <RadzenLabel Text="Nom du Pilote (Windows)" Component="Nom" />
            <RadzenTextBox Name="Nom" @bind-Value="@piloteEdit.Nom" Style="width: 100%;" />
            <RadzenRequiredValidator Component="Nom" Text="Nom requis" Popup="true" />
            <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-tertiary-color);">
                Copiez ici le nom exact tel qu'il apparaît dans le Gestionnaire d'impression Windows.
            </RadzenText>
        </div>

        <div>
            <RadzenLabel Text="Version" Component="Version" />
            <RadzenTextBox Name="Version" @bind-Value="@piloteEdit.Version" Style="width: 100%;" Placeholder="Ex: 7.1.0" />
        </div>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Class="rz-mt-4">
            @if (piloteEdit.Id != 0)
            {
                <AuthorizeView Policy="DRIVER_DELETE">
                    <Authorized Context="auth">
                        <RadzenButton ButtonStyle="ButtonStyle.Danger" Icon="delete" Variant="Variant.Flat" Text="Supprimer" Click="@OnDelete" />
                    </Authorized>
                </AuthorizeView>
            }
            else
            {

                <div></div>
            }

            <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
                <RadzenButton ButtonType="ButtonType.Submit" Text="Enregistrer" Icon="save" ButtonStyle="ButtonStyle.Primary" />
            </RadzenStack>
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public Pilote PiloteToEdit { get; set; } = new();
    private Pilote piloteEdit = new();

    protected override void OnInitialized()
    {
        piloteEdit = new Pilote { Id = PiloteToEdit.Id, Nom = PiloteToEdit.Nom, Version = PiloteToEdit.Version };
    }

    private async Task OnSubmit(Pilote args)
    {
        try
        {
            if (piloteEdit.Id == 0) await Http.PostAsJsonAsync("api/Pilotes", piloteEdit);
            else await Http.PutAsJsonAsync($"api/Pilotes/{piloteEdit.Id}", piloteEdit);

            NotificationService.Notify(NotificationSeverity.Success, "Succès", "Pilote enregistré.");
            DialogService.Close(true);
        }
        catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message); }
    }

    private async Task OnDelete()
    {
        var confirm = await DialogService.Confirm("Supprimer ce pilote ?", "Confirmation", new ConfirmOptions { OkButtonText = "Oui", CancelButtonText = "Non" });
        if (confirm == true)
        {
            try { await Http.DeleteAsync($"api/Pilotes/{piloteEdit.Id}"); DialogService.Close(true); }
            catch (Exception ex) { NotificationService.Notify(NotificationSeverity.Error, "Erreur", ex.Message); }
        }
    }
}