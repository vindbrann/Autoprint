@using Autoprint.Shared
@using Autoprint.Shared.DTOs
@using Autoprint.Web.Services
@inject HttpClient Http
@inject AlertService AlertService

@if (Show)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title"><i class="bi bi-hdd-network me-2"></i>Scanner le Serveur</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OnCancel"></button>
                </div>

                <div class="modal-body">
                    @if (isSyncing)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary mb-3" role="status"></div>
                            <p>Analyse des pilotes WMI en cours...</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger">
                            <strong>Erreur :</strong> @errorMessage
                        </div>
                    }
                    else if (result != null)
                    {
                        <div class="alert alert-success">
                            <h6 class="alert-heading">Synchronisation terminée !</h6>
                            <ul class="mb-0 mt-2">
                                <li>➕ <strong>@result.Added</strong> ajoutés</li>
                                <li>🔄 <strong>@result.Updated</strong> mis à jour</li>
                                <li>❌ <strong>@result.Deleted</strong> nettoyés</li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <p>Lancer la synchronisation avec le Spouleur Windows ?</p>
                    }
                </div>

                <div class="modal-footer">
                    @if (!isSyncing)
                    {
                        <button class="btn btn-secondary" @onclick="OnCancel">Fermer</button>
                        @if (result == null)
                        {
                            <button class="btn btn-primary" @onclick="LancerSynchro">Lancer le Scan</button>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnScanComplete { get; set; }

    private bool isSyncing = false;
    private BatchResult? result;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        if (!Show)
        {
            result = null;
            errorMessage = null;
        }
    }

    private async Task LancerSynchro()
    {
        isSyncing = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsync("api/Pilotes/sync", null);

            if (response.IsSuccessStatusCode)
            {
                result = await response.Content.ReadFromJsonAsync<BatchResult>();
                await OnScanComplete.InvokeAsync();
                await AlertService.RefreshState();
            }
            else
            {
                errorMessage = $"Erreur serveur : {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Erreur technique : " + ex.Message;
        }
        finally
        {
            isSyncing = false;
        }
    }
}