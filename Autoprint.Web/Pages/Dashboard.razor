@page "/"
@using Autoprint.Shared.DTOs
@using Autoprint.Shared
@using Autoprint.Web.Services
@using Radzen
@using Radzen.Blazor
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject NavigationManager NavManager
@inject CustomAuthStateProvider AuthProvider

<PageTitle>Tableau de Bord</PageTitle>

@* EN-TÊTE *@
<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Class="rz-mb-4">
    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H3" Class="rz-mb-0" Style="font-weight: 700; letter-spacing: -0.5px;">
        Tableau de Bord
    </RadzenText>
    <RadzenButton Icon="refresh" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Click="@ChargerDonnees" IsBusy="@isLoading" />
</RadzenStack>

@if (isLoading && stats == null)
{
    @* MODE SKELETON *@
    <RadzenRow Class="rz-mb-4">
        @for (int i = 0; i < 3; i++)
        {
            <RadzenColumn Size="12" SizeMD="4"><RadzenCard style="height: 100px;"><RadzenSkeleton Width="100%" Height="100%" /></RadzenCard></RadzenColumn>
        }
    </RadzenRow>
    <RadzenRow>
        <RadzenColumn Size="12" SizeLG="8">
            <RadzenCard style="height: 400px;" Class="rz-mb-4"><RadzenSkeleton Width="100%" Height="100%" /></RadzenCard>
            <RadzenCard style="height: 150px;"><RadzenSkeleton Width="100%" Height="100%" /></RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeLG="4">
            <RadzenCard style="height: 600px;"><RadzenSkeleton Width="100%" Height="100%" /></RadzenCard>
        </RadzenColumn>
    </RadzenRow>
}
else if (stats != null)
{
    @* --- 1. INDICATEURS CLÉS (KPI) --- *@
    <RadzenRow Class="rz-mb-4" Gap="1.5rem">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Flat" Class="kpi-card" Style="border-left: 4px solid var(--rz-primary); background-color: var(--rz-base-100);">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Overline" Class="rz-mb-0 rz-color-primary">PARC ACTIF</RadzenText>
                        <RadzenText TextStyle="TextStyle.DisplayH4" Class="rz-mb-0"><b>@stats.TotalImprimantes</b></RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="print" Style="font-size: 2.5rem; opacity: 0.2;" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Flat" Class="kpi-card" Style="border-left: 4px solid var(--rz-success); background-color: var(--rz-base-100);">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Overline" Class="rz-mb-0 rz-color-success">PILOTES</RadzenText>
                        <RadzenText TextStyle="TextStyle.DisplayH4" Class="rz-mb-0"><b>@stats.TotalPilotes</b></RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="usb" Style="font-size: 2.5rem; opacity: 0.2;" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Flat" Class="kpi-card" Style="border-left: 4px solid var(--rz-info); background-color: var(--rz-base-100);">
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween">
                    <RadzenStack Gap="0">
                        <RadzenText TextStyle="TextStyle.Overline" Class="rz-mb-0 rz-color-info">LIEUX</RadzenText>
                        <RadzenText TextStyle="TextStyle.DisplayH4" Class="rz-mb-0"><b>@stats.TotalLieux</b></RadzenText>
                    </RadzenStack>
                    <RadzenIcon Icon="place" Style="font-size: 2.5rem; opacity: 0.2;" />
                </RadzenStack>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>

    <RadzenRow Gap="1.5rem">

        @* --- COLONNE GAUCHE (Extensible) --- *@
        <RadzenColumn Size="12" SizeLG="@(ShowRightColumn ? 8 : 12)">
            <RadzenStack Gap="1.5rem">

                @* 2. GRAPHIQUE *@
                <RadzenCard Class="rz-p-4" Style="min-height: 400px; border-radius: 8px;">
                    <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-4">Répartition par Modèle</RadzenText>
                    @if (stats.RepartitionModeles.Any())
                    {
                        <RadzenChart Style="height: 320px;">
                            <RadzenDonutSeries Data="@stats.RepartitionModeles" CategoryProperty="Label" ValueProperty="Value"
                                               Fills="@(new[] { "#4340d2", "#e91e63", "#4caf50", "#ff9800", "#00bcd4", "#9c27b0" })">
                                <TitleTemplate>
                                    <div class="rz-donut-content">
                                        <div style="font-size: 2rem; font-weight: 800;">@stats.TotalImprimantes</div>
                                        <div style="color: var(--rz-text-tertiary-color); font-size: 0.7rem;">TOTAL</div>
                                    </div>
                                </TitleTemplate>
                            </RadzenDonutSeries>
                            <RadzenLegend Position="LegendPosition.Right" Visible="true" />
                        </RadzenChart>
                    }
                    else
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Info" Variant="Variant.Flat" Shade="Shade.Lighter">Données insuffisantes.</RadzenAlert>
                    }
                </RadzenCard>

                @* 3. ÉTAT DU SERVICE (CONNECTÉ AU BACKEND) *@
                <RadzenCard Class="rz-p-4" Style="border-radius: 8px;">
                    <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-4">État du Service</RadzenText>
                    <RadzenRow>
                        @* Spouleur Windows (Dynamique) *@
                        <RadzenColumn Size="4" Class="rz-text-align-center" Style="border-right: 1px solid var(--rz-border-color);">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-1 text-muted">Spouleur Windows</RadzenText>
                            @if (stats.IsSpoolerRunning)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Success" Text="EN LIGNE" Variant="Variant.Flat" class="rz-px-3 rz-py-1" />
                            }
                            else
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="ARRÊTÉ" Variant="Variant.Flat" class="rz-px-3 rz-py-1" />
                            }
                        </RadzenColumn>

                        @* Version *@
                        <RadzenColumn Size="4" Class="rz-text-align-center" Style="border-right: 1px solid var(--rz-border-color);">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-1 text-muted">Version Serveur</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-0 fw-bold">
                                @stats.ServerVersion
                            </RadzenText>

                        </RadzenColumn>

                        @* Alertes Synchro (Dynamique) *@
                        <RadzenColumn Size="4" Class="rz-text-align-center">
                            <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-1 text-muted">Erreurs Synchro</RadzenText>
                            @if (stats.SyncErrorCount > 0)
                            {
                                <RadzenBadge BadgeStyle="BadgeStyle.Danger" Text="@($"{stats.SyncErrorCount} erreurs")" Variant="Variant.Flat"
                                             Style="cursor: pointer;" @onclick="@(() => NavManager.NavigateTo("imprimantes"))" />
                            }
                            else
                            {
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="0.2rem">
                                    <RadzenIcon Icon="check_circle" Style="color: var(--rz-success); font-size: 1rem;" />
                                    <span style="color: var(--rz-success); font-weight: bold;">0</span>
                                </RadzenStack>
                            }
                        </RadzenColumn>
                    </RadzenRow>
                </RadzenCard>

            </RadzenStack>
        </RadzenColumn>

        @* --- COLONNE DROITE (Conditionnelle) --- *@
        @if (ShowRightColumn)
        {
            <RadzenColumn Size="12" SizeLG="4">
                <RadzenStack Gap="1.5rem" Style="height: 100%;">

                    @* 4. SANTÉ PILOTES *@
                    @if (canReadDrivers)
                    {
                        <RadzenCard Class="rz-p-3" Style="border-radius: 8px; background-color: var(--rz-base-100);">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Class="rz-mb-2">
                                <RadzenIcon Icon="inventory_2" Style="color: var(--rz-secondary);" />
                                <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-0">Référentiel Pilotes</RadzenText>
                            </RadzenStack>

                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px;">
                                <span class="rz-text-caption">Taux d'utilisation</span>
                                <span class="rz-text-caption" style="font-weight: bold;">@usagePercent%</span>
                            </div>

                            <RadzenProgressBar Value="@usagePercent" ShowValue="false" Style="height: 8px;" ProgressBarStyle="ProgressBarStyle.Info" />

                            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" Class="rz-mt-2">
                                <span class="rz-text-caption text-muted">@assignedDrivers assignés</span>
                                <span class="rz-text-caption text-muted">@orphanedDrivers en réserve</span>
                            </RadzenStack>
                        </RadzenCard>
                    }

                    @* 5. TIMELINE AUDIT *@
                    @if (canReadAudit)
                    {
                        <RadzenCard Class="rz-p-0" Style="flex: 1; border-radius: 8px; overflow: hidden; display: flex; flex-direction: column;">
                            <div class="rz-p-3" style="border-bottom: 1px solid var(--rz-border-color); background-color: var(--rz-base-200);">
                                <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-mb-0">Dernières Activités</RadzenText>
                            </div>

                            <div style="flex: 1; overflow-y: auto; padding: 1rem;">
                                @if (recentLogs == null || !recentLogs.Any())
                                {
                                    <div class="rz-text-align-center rz-p-2 text-muted small">Aucune activité récente.</div>
                                }
                                else
                                {
                                    <RadzenStack Gap="1rem">
                                        @foreach (var log in recentLogs)
                                        {
                                            <div style="display: flex; gap: 10px; align-items: flex-start;">
                                                <div style="margin-top: 2px;">
                                                    @if (log.Action.Contains("CREATE") || log.Action.Contains("ADD"))
                                                    {
                                                        <RadzenIcon Icon="add_circle" Style="color: var(--rz-success); font-size: 1rem;" />
                                                    }
                                                    else if (log.Action.Contains("DELETE"))
                                                    {

                                                        <RadzenIcon Icon="delete" Style="color: var(--rz-danger); font-size: 1rem;" />
                                                    }
                                                    else if (log.Action.Contains("UPDATE"))
                                                    {

                                                        <RadzenIcon Icon="edit" Style="color: var(--rz-warning); font-size: 1rem;" />
                                                    }
                                                    else
                                                    {

                                                        <RadzenIcon Icon="info" Style="color: var(--rz-info); font-size: 1rem;" />
                                                    }
                                                </div>
                                                <div style="flex: 1; overflow: hidden;">
                                                    <div style="font-size: 0.8rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@log.ActionLisible">
                                                        @log.ActionLisible
                                                    </div>
                                                    <div style="font-size: 0.7rem; color: var(--rz-text-tertiary-color);">
                                                        @log.Utilisateur • @GetTimeAgo(log.DateAction)
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </RadzenStack>
                                }
                            </div>
                        </RadzenCard>
                    }

                </RadzenStack>
            </RadzenColumn>
        }

    </RadzenRow>
}

<style>
    .kpi-card {
        transition: transform 0.2s;
    }

        .kpi-card:hover {
            transform: translateY(-2px);
        }
</style>

@code {
    private DashboardStatsDto? stats;
    private List<AuditLogDto>? recentLogs;
    private bool isLoading = true;

    // Droits
    private bool canReadAudit = false;
    private bool canReadDrivers = false;
    private bool canReadModels = false;

    // Stats techniques
    private int orphanedDrivers = 0;
    private int assignedDrivers = 0;
    private double usagePercent = 0;

    private bool ShowRightColumn => canReadAudit || canReadDrivers;

    protected override async Task OnInitializedAsync()
    {
        await ChargerDonnees();
    }

    private async Task ChargerDonnees()
    {
        isLoading = true;
        try
        {
            canReadAudit = await AuthProvider.HasPermission("Permission", "AUDIT_READ");
            canReadDrivers = await AuthProvider.HasPermission("Permission", "DRIVER_READ");
            canReadModels = await AuthProvider.HasPermission("Permission", "MODEL_READ");

            // 1. Stats Globales (Inclut maintenant IsSpoolerRunning et SyncErrorCount)
            var t1 = Http.GetFromJsonAsync<DashboardStatsDto>("api/Dashboard");

            // 2. Logs (Conditionnel)
            Task<PaginatedList<AuditLogDto>>? t2 = null;
            if (canReadAudit) t2 = Http.GetFromJsonAsync<PaginatedList<AuditLogDto>>("api/Audit?page=1&pageSize=5");

            // 3. Pilotes & Modèles (Conditionnel)
            Task<List<Pilote>>? t3 = null;
            Task<List<Modele>>? t4 = null;
            if (canReadDrivers && canReadModels)
            {
                t3 = Http.GetFromJsonAsync<List<Pilote>>("api/Pilotes");
                t4 = Http.GetFromJsonAsync<List<Modele>>("api/Modeles");
            }

            await Task.WhenAll(t1);
            if (t2 != null) await t2;
            if (t3 != null && t4 != null) await Task.WhenAll(t3, t4);

            stats = t1.Result;
            recentLogs = (t2 != null && t2.Result != null) ? t2.Result.Items : new List<AuditLogDto>();

            // Calcul Santé Pilotes (Client-side)
            if (t3 != null && t4 != null)
            {
                var pilotes = t3.Result ?? new();
                var modeles = t4.Result ?? new();
                var usedDriverIds = modeles.Select(m => m.PiloteId).Distinct().ToHashSet();
                orphanedDrivers = pilotes.Count(p => !usedDriverIds.Contains(p.Id));
                assignedDrivers = pilotes.Count - orphanedDrivers;
                if (pilotes.Count > 0) usagePercent = Math.Round((double)assignedDrivers / pilotes.Count * 100);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erreur Dashboard : " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetTimeAgo(DateTime date)
    {
        var span = DateTime.UtcNow - date.ToUniversalTime();
        if (span.TotalMinutes < 1) return "À l'instant";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes} min";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours} h";
        return date.ToLocalTime().ToString("dd/MM");
    }
}