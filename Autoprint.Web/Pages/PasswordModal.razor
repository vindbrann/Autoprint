@using Autoprint.Shared.DTOs
@using System.ComponentModel.DataAnnotations
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject DialogService DialogService
@inject NotificationService NotificationService

<RadzenTemplateForm TItem="ChangePasswordDto" Data="@Model" Submit="@OnSubmit">
    <RadzenStack Gap="1.5rem">
        
        @if (IsForced)
        {
            <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat" Shade="Shade.Lighter" AllowClose="false">
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                    <RadzenIcon Icon="lock_clock" />
                    <div>
                        <strong>Action requise :</strong> Votre mot de passe a expiré.<br/>
                        Vous devez le changer pour continuer.
                    </div>
                </RadzenStack>
            </RadzenAlert>
        }

        <RadzenStack Gap="1rem">
            <div>
                <RadzenLabel Text="Mot de passe actuel" Component="CurrentPwd" />
                <RadzenPassword Name="CurrentPwd" @bind-Value="@Model.CurrentPassword" Style="width: 100%;" />
                <RadzenRequiredValidator Component="CurrentPwd" Text="Requis" Popup="true" />
            </div>

            <RadzenDivider />

            <div>
                <RadzenLabel Text="Nouveau mot de passe" Component="NewPwd" />
                <RadzenPassword Name="NewPwd" @bind-Value="@Model.NewPassword" Style="width: 100%;" />
                <RadzenRequiredValidator Component="NewPwd" Text="Requis" Popup="true" />
                <RadzenLengthValidator Component="NewPwd" Min="6" Text="6 caractères minimum" Popup="true" />
            </div>

            <div>
                <RadzenLabel Text="Confirmer le nouveau" Component="ConfirmPwd" />
                <RadzenPassword Name="ConfirmPwd" @bind-Value="@Model.ConfirmPassword" Style="width: 100%;" />
                <RadzenCompareValidator Component="ConfirmPwd" Value="@Model.NewPassword" Text="Les mots de passe ne correspondent pas" Popup="true" />
            </div>
        </RadzenStack>

        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="1rem" Class="rz-mt-2">
            @if (!IsForced)
            {
                <RadzenButton Text="Annuler" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(null))" />
            }
            <RadzenButton ButtonType="ButtonType.Submit" Text="Valider le changement" Icon="check_circle" ButtonStyle="ButtonStyle.Primary" />
        </RadzenStack>

    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public bool IsForced { get; set; } = false;

    private ChangePasswordDto Model = new();

    private async Task OnSubmit(ChangePasswordDto args)
    {
        // On renvoie le DTO rempli au parent
        DialogService.Close(args);
    }
}