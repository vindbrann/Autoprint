@page "/users"
@using Autoprint.Shared.DTOs
@using Autoprint.Web.Services
@inject IUserService UserService
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject IRoleService RoleService

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👥 Gestion des Utilisateurs</h2>
        <AuthorizeView Policy="USER_WRITE">
            <Authorized>
                <button class="btn btn-primary" @onclick="ShowAddForm">
                    <i class="oi oi-plus"></i> Nouvel Utilisateur
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (users == null)
            {
                <p class="text-center p-3">Chargement...</p>
            }
            else
            {
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Identifiant</th>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Rôle</th>
                            <th>Dernière connexion</th>
                            <th>État</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in users)
                        {
                            <tr>
                                <td>
                                    @if (u.IsAdUser)
                                    {
                                        <span class="badge bg-info text-dark me-1" title="Utilisateur Active Directory">AD</span>
                                    }
                                    <span class="fw-bold">@u.Username</span>
                                </td>
                                <td>@u.DisplayName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(u.Email))
                                    {
                                        <a href="mailto:@u.Email" class="text-decoration-none">@u.Email</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Non renseigné</span>
                                    }
                                </td>
                                <td>
                                    @foreach (var r in u.Roles)
                                    {
                                        <span class="badge bg-secondary me-1">@r</span>
                                    }
                                </td>
                                <td class="small text-muted">@(u.LastLogin == DateTime.MinValue ? "Jamais" : u.LastLogin.ToString("g"))</td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success">Actif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Désactivé</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <AuthorizeView Policy="USER_WRITE">
                                        <Authorized Context="authContext">
                                            <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditUser(u)">
                                                ✏️
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                    <AuthorizeView Policy="USER_DELETE">
                                        <Authorized Context="authContext">
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteUser(u)">
                                                🗑️
                                            </button>
                                        </Authorized>
                                    </AuthorizeView>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@if (showForm)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">
                        @(editMode ? "✏️ Modifier l'utilisateur" : "➕ Créer un utilisateur")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CancelForm"></button>
                </div>

                <EditForm Model="@currentUserModel" OnValidSubmit="SaveUser">
                    <DataAnnotationsValidator />

                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Identifiant (Login)</label>
                                @if (editMode)
                                {
                                    <input type="text" class="form-control bg-light" value="@editingUsername" disabled readonly />
                                    <div class="form-text">L'identifiant ne peut pas être modifié.</div>
                                }
                                else
                                {
                                    <InputText class="form-control" @bind-Value="newUserModel.Username" placeholder="ex: jdupont" />
                                    <ValidationMessage For="@(() => newUserModel.Username)" />
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">Rôle</label>
                                <select class="form-select" @bind="selectedRoleId">
                                    @foreach (var role in availableRoles)
                                    {
                                        <option value="@role.Id">@role.Name</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Nom Affiché</label>
                                @if (editMode)
                                {
                                    <InputText class="form-control" @bind-Value="editUserModel.DisplayName" />
                                }
                                else
                                {
                                    <InputText class="form-control" @bind-Value="newUserModel.DisplayName" placeholder="ex: Jean Dupont" />
                                }
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Email</label>
                                @if (editMode)
                                {
                                    <InputText class="form-control" @bind-Value="editUserModel.Email" type="email" placeholder="jean.dupont@societe.com" />
                                    <ValidationMessage For="@(() => editUserModel.Email)" />
                                }
                                else
                                {
                                    <InputText class="form-control" @bind-Value="newUserModel.Email" type="email" placeholder="jean.dupont@societe.com" />
                                    <ValidationMessage For="@(() => newUserModel.Email)" />
                                }
                            </div>

                            <div class="col-12"><hr /></div>

                            <div class="col-md-6">
                                <label class="form-label fw-bold">
                                    Mot de passe @(editMode ? "(Optionnel)" : "*")
                                </label>
                                @if (editMode)
                                {
                                    <InputText type="password" class="form-control" @bind-Value="editUserModel.NewPassword" placeholder="Laisser vide pour ne pas changer" />
                                }
                                else
                                {
                                    <InputText type="password" class="form-control" @bind-Value="newUserModel.Password" />
                                    <ValidationMessage For="@(() => newUserModel.Password)" />
                                }
                            </div>

                            @if (editMode)
                            {
                                <div class="col-md-6">
                                    <div class="card bg-light h-100">
                                        <div class="card-body d-flex flex-column justify-content-center">

                                            <div class="form-check form-switch mb-2">
                                                <InputCheckbox class="form-check-input" @bind-Value="editUserModel.IsActive" id="chkActive" />
                                                <label class="form-check-label" for="chkActive">Compte Actif</label>
                                            </div>

                                            <div class="form-check form-switch">
                                                <InputCheckbox class="form-check-input" @bind-Value="editUserModel.ForceChangePassword" id="chkForce" />
                                                <label class="form-check-label text-warning fw-bold" for="chkForce">
                                                    Forcer le changement de mot de passe
                                                </label>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" @onclick="CancelForm">Annuler</button>
                        <button type="submit" class="btn btn-success px-4">
                            @(editMode ? "Enregistrer les modifications" : "Créer l'utilisateur")
                        </button>
                    </div>

                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<UserViewDto>? users;
    private List<RoleViewDto> availableRoles = new();

    private bool showForm = false;
    private bool editMode = false;

    private CreateUserDto newUserModel = new();
    private UpdateUserDto editUserModel = new();
    private string editingUsername = "";
    private int editingUserId = 0;

    private int selectedRoleId = 1;

    private object currentUserModel => editMode ? (object)editUserModel : newUserModel;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var usersTask = UserService.GetUsers();
        var rolesTask = RoleService.GetRoles();
        await Task.WhenAll(usersTask, rolesTask);
        users = usersTask.Result;
        availableRoles = rolesTask.Result;

        if (availableRoles.Any())
        {
            selectedRoleId = availableRoles.First().Id;
        }
    }

    private void ShowAddForm()
    {
        newUserModel = new CreateUserDto();
        var defaultRole = availableRoles.FirstOrDefault(r => r.Name != "SuperAdmin") ?? availableRoles.FirstOrDefault();
        selectedRoleId = defaultRole?.Id ?? 1;
        editMode = false;
        showForm = true;
    }

    private void EditUser(UserViewDto user)
    {
        editingUserId = user.Id;
        editingUsername = user.Username;

        editUserModel = new UpdateUserDto
        {
            DisplayName = user.DisplayName,
            Email = user.Email, // <-- On charge l'email existant
            IsActive = user.IsActive,
            RoleId = 1,
            ForceChangePassword = false // Par défaut à false quand on ouvre
        };

        var userRoleName = user.Roles.FirstOrDefault();
        if (userRoleName != null)
        {
            var matchingRole = availableRoles.FirstOrDefault(r => r.Name == userRoleName);
            if (matchingRole != null) selectedRoleId = matchingRole.Id;
        }

        editMode = true;
        showForm = true;
    }

    private void CancelForm()
    {
        showForm = false;
    }

    private async Task SaveUser()
    {
        try
        {
            if (editMode)
            {
                editUserModel.RoleId = selectedRoleId;
                await UserService.UpdateUser(editingUserId, editUserModel);
            }
            else
            {
                newUserModel.RoleId = selectedRoleId;
                await UserService.CreateUser(newUserModel);
            }
            showForm = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", "Erreur lors de l'enregistrement : " + ex.Message);
        }
    }

    private async Task DeleteUser(UserViewDto user)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Supprimer l'utilisateur {user.Username} ?"))
            return;

        await UserService.DeleteUser(user.Id);
        await LoadData();
    }
}