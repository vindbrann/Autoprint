@using Autoprint.Shared
@using Autoprint.Web.Services
@inject HttpClient Http
@inject CustomAuthStateProvider AuthProvider

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(Model.Id == 0 ? "Ajouter un Modèle" : "Modifier le Modèle")</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@Model" OnValidSubmit="HandleValidSubmit">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Nom du Modèle</label>
                            <InputText class="form-control" @bind-Value="Model.Nom" placeholder="Ex: LaserJet Pro 400" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Marque <span class="text-danger">*</span></label>
                            <select class="form-select @(showMarqueError ? "is-invalid" : "")"
                                    @bind="Model.MarqueId"
                                    disabled="@(!CanReadMarques)">
                                <option value="0">-- Choisir une marque --</option>
                                @if (listeMarques != null)
                                {
                                    @foreach (var marque in listeMarques)
                                    {
                                        <option value="@marque.Id">@marque.Nom</option>
                                    }
                                }
                            </select>

                            @if (!CanReadMarques)
                            {
                                <div class="form-text text-danger">
                                    <i class="bi bi-lock-fill"></i> Vous n'avez pas l'autorisation de voir les marques.
                                </div>
                            }
                            @if (showMarqueError)
                            {
                                <div class="invalid-feedback">La marque est obligatoire.</div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Pilote par défaut <span class="text-danger">*</span></label>
                            <small class="text-muted d-block mb-1">Indispensable pour l'installation automatique.</small>

                            <select class="form-select @(showPiloteError ? "is-invalid" : "")"
                                    @bind="Model.PiloteId"
                                    disabled="@(!CanReadPilotes)">
                                <option value="">-- Choisir un pilote --</option>
                                @if (listePilotes != null)
                                {
                                    @* FILTRE : On n'affiche que les pilotes valides OU celui déjà sélectionné *@
                                    @foreach (var pilote in listePilotes.Where(p => p.EstInstalle || p.Id == Model.PiloteId))
                                    {
                                        <option value="@pilote.Id">
                                            @pilote.Nom
                                            @if (!pilote.EstInstalle)
                                            {
                                                <text> (⚠️ INTROUVABLE)</text>
                                            }
                                        </option>
                                    }
                                }
                            </select>

                            @if (!CanReadPilotes)
                            {
                                <div class="form-text text-danger">
                                    <i class="bi bi-lock-fill"></i> Vous n'avez pas l'autorisation de voir les pilotes.
                                </div>
                            }
                            @if (showPiloteError)
                            {
                                <div class="invalid-feedback">Vous devez associer un pilote à ce modèle.</div>
                            }
                        </div>

                        <div class="modal-footer">
                            @if (Model.Id != 0)
                            {
                                <AuthorizeView Policy="MODEL_DELETE">
                                    <Authorized Context="authContext">
                                        <button type="button" class="btn btn-danger me-auto" @onclick="OnDelete">Supprimer</button>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            <button type="button" class="btn btn-secondary" @onclick="OnCancel">Annuler</button>
                            <button type="submit" class="btn btn-primary">Enregistrer</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Modele Model { get; set; } = new();
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    private List<Marque>? listeMarques;
    private List<Pilote>? listePilotes;

    private bool CanReadMarques { get; set; }
    private bool CanReadPilotes { get; set; }

    // Flags d'erreur
    private bool showMarqueError = false;
    private bool showPiloteError = false;

    protected override async Task OnInitializedAsync()
    {
        CanReadMarques = await AuthProvider.HasPermission("Permission", "BRAND_READ");
        CanReadPilotes = await AuthProvider.HasPermission("Permission", "DRIVER_READ");

        try
        {
            var tasks = new List<Task>();

            if (CanReadMarques)
                tasks.Add(Task.Run(async () => listeMarques = await Http.GetFromJsonAsync<List<Marque>>("api/Marques")));

            if (CanReadPilotes)
                tasks.Add(Task.Run(async () => listePilotes = await Http.GetFromJsonAsync<List<Pilote>>("api/Pilotes")));

            if (tasks.Any()) await Task.WhenAll(tasks);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Erreur chargement données : {ex.Message}");
        }
    }

    private async Task HandleValidSubmit()
    {
        bool hasError = false;

        if (Model.MarqueId == 0)
        {
            showMarqueError = true;
            hasError = true;
        }
        else
        {
            showMarqueError = false;
        }

        if (Model.PiloteId == null || Model.PiloteId == 0)
        {
            showPiloteError = true;
            hasError = true;
        }
        else
        {
            showPiloteError = false;
        }

        if (hasError) return;

        await OnSave.InvokeAsync();
    }
}