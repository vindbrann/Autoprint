@page "/audit"
@using Autoprint.Shared
@using Autoprint.Shared.DTOs
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🕵️ Journal d'Audit</h3>
        <button class="btn btn-outline-danger btn-sm" @onclick="PurgerLogs" title="Supprimer les logs de plus de 30 jours">
            <i class="bi bi-trash3"></i> Nettoyage
        </button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-start-0"
                       placeholder="Rechercher par utilisateur, action ou détail..."
                       @bind="searchQuery" @bind:event="oninput" @onkeyup="HandleSearch" />
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <button class="btn btn-outline-secondary" @onclick="ClearSearch">X</button>
                }
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        @if (logs == null)
        {
            <div class="text-center p-5">
                <div class="spinner-border text-primary"></div>
            </div>
        }
        else if (logs.Items.Count == 0)
        {
            <div class="text-center p-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p>Aucun événement trouvé.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 table-striped">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 160px;">Date</th>
                            <th style="width: 100px;">Niveau</th>
                            <th style="width: 150px;">Utilisateur</th>
                            <th style="width: 150px;">Action</th>
                            <th>Détails</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in logs.Items)
                        {
                            <tr>
                                <td class="small text-muted">@log.DateAction.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@RenderBadge(log.Niveau)</td>
                                <td class="fw-bold text-primary small">@log.Utilisateur</td>
                                <td class="small">@log.Action</td>
                                <td class="text-muted small">@log.Details</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="card-footer bg-white d-flex justify-content-between align-items-center py-3">
                <span class="small text-muted">
                    Page @logs.PageIndex sur @logs.TotalPages (Total : @logs.TotalCount)
                </span>
                <div>
                    <button class="btn btn-sm btn-outline-secondary me-1" disabled="@(!logs.HasPreviousPage)" @onclick="PrevPage">
                        &laquo; Précédent
                    </button>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(!logs.HasNextPage)" @onclick="NextPage">
                        Suivant &raquo;
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private PaginatedList<AuditLog>? logs;
    private string searchQuery = "";
    private int currentPage = 1;
    private int pageSize = 20;

    protected override async Task OnInitializedAsync()
    {
        await LoadLogs();
    }

    private async Task LoadLogs()
    {
        try
        {
            // Construction de l'URL avec paramètres
            var url = $"api/Audit?page={currentPage}&pageSize={pageSize}";
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                url += $"&search={Uri.EscapeDataString(searchQuery)}";
            }

            logs = await Http.GetFromJsonAsync<PaginatedList<AuditLog>>(url);
        }
        catch (Exception ex)
        {
            Console.WriteLine("Erreur chargement logs : " + ex.Message);
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            currentPage = 1; // Retour page 1 si nouvelle recherche
            await LoadLogs();
        }
    }

    private async Task ClearSearch()
    {
        searchQuery = "";
        currentPage = 1;
        await LoadLogs();
    }

    private async Task NextPage()
    {
        if (logs != null && logs.HasNextPage)
        {
            currentPage++;
            await LoadLogs();
        }
    }

    private async Task PrevPage()
    {
        if (logs != null && logs.HasPreviousPage)
        {
            currentPage--;
            await LoadLogs();
        }
    }

    private async Task PurgerLogs()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Voulez-vous vraiment supprimer définitivement les logs vieux de plus de 30 jours ?")) return;

        var res = await Http.DeleteAsync("api/Audit/cleanup");
        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "Nettoyage effectué.");
            currentPage = 1;
            await LoadLogs();
        }
    }

    // Helper pour les couleurs de badges
    private RenderFragment RenderBadge(string niveau) => __builder =>
    {
        string colorClass = niveau switch
        {
            "ERROR" => "bg-danger",
            "WARNING" => "bg-warning text-dark",
            "INFO" => "bg-info text-dark",
            _ => "bg-secondary"
        };

        <span class="badge @colorClass">@niveau</span>
    };
}