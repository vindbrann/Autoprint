@page "/lieux"
@using Autoprint.Shared
@inject HttpClient Http

<PageTitle>Gestion des Lieux</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>📍 Gestion des Lieux</h3>
    <AuthorizeView Policy="LOCATION_WRITE">
    <Authorized>
    <button class="btn btn-success" @onclick="OuvrirAjout">
        <i class="bi bi-plus-circle"></i> Nouveau Lieu
    </button>
        </Authorized>
    </AuthorizeView>
</div>

@if (messageErreur != null)
{
    <div class="alert alert-danger">@messageErreur</div>
}
else if (lieux == null)
{
    <div class="spinner-border text-primary" role="status"></div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nom</th>
                <th>Code</th>
                <th>Réseau (CIDR)</th>
                <th style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lieu in lieux)
            {
                <tr>
                    <td>@lieu.Nom</td>
                    <td>
                        @if (!string.IsNullOrEmpty(lieu.Code))
                        {
                            <span class="badge bg-secondary">@lieu.Code</span>
                        }
                        else
                        {
                            <span class="text-muted small">-</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-info text-dark">@lieu.CidrIpv4</span>
                    </td>
                    <td>
                        <AuthorizeView Policy="LOCATION_WRITE">
                            <Authorized>
                                <button class="btn btn-sm btn-primary" @onclick="() => OuvrirEdition(lieu)">
                                    <i class="bi bi-pencil"></i> Modifier
                                </button>
                            </Authorized>
                            <NotAuthorized>
                                <button class="btn btn-sm btn-secondary" disabled title="Droit de modification requis">
                                    <i class="bi bi-pencil"></i> Modifier
                                </button>
                            </NotAuthorized>
                        </AuthorizeView>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<LieuModal Show="afficherModal"
           Model="lieuEnCours"
           OnCancel="FermerModal"
           OnSave="Sauvegarder"
           OnDelete="Supprimer" />

@code {
    private List<Emplacement>? lieux;
    private Emplacement lieuEnCours = new();
    private bool afficherModal = false;
    private string? messageErreur;

    protected override async Task OnInitializedAsync()
    {
        await ChargerListe();
    }

    private async Task ChargerListe()
    {
        try
        {
            lieux = await Http.GetFromJsonAsync<List<Emplacement>>("api/Emplacements");
        }
        catch (Exception ex)
        {
            messageErreur = "Erreur : " + ex.Message;
        }
    }

    private void OuvrirAjout()
    {
        lieuEnCours = new Emplacement();
        afficherModal = true;
    }

    private void OuvrirEdition(Emplacement l)
    {
        lieuEnCours = new Emplacement
        {
            Id = l.Id,
            Nom = l.Nom,
            Code = l.Code,
            CidrIpv4 = l.CidrIpv4 
        };
        afficherModal = true;
    }

    private void FermerModal() => afficherModal = false;

    private async Task Sauvegarder()
    {
        if (lieuEnCours.Id == 0)
            await Http.PostAsJsonAsync("api/Emplacements", lieuEnCours);
        else
            await Http.PutAsJsonAsync($"api/Emplacements/{lieuEnCours.Id}", lieuEnCours);

        afficherModal = false;
        await ChargerListe();
    }

    private async Task Supprimer()
    {
        if (lieuEnCours.Id > 0)
        {
            await Http.DeleteAsync($"api/Emplacements/{lieuEnCours.Id}");
            afficherModal = false;
            await ChargerListe();
        }
    }
}