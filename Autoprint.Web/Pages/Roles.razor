@page "/roles"
@using Autoprint.Shared.DTOs
@using Autoprint.Web.Services
@inject IRoleService RoleService
@inject IJSRuntime JS
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🛡️ Gestion des Rôles et Permissions</h2>
        <button class="btn btn-primary" @onclick="ShowAddForm">
            <i class="oi oi-plus"></i> Nouveau Rôle
        </button>
    </div>

    @if (showForm)
    {
        <div class="card p-4 mb-4 shadow-sm bg-light">
            <h4>@(editMode ? "Modifier le rôle" : "Créer un rôle")</h4>
            <EditForm Model="@currentModel" OnValidSubmit="SaveRole">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Nom du Groupe</label>
                        <InputText class="form-control" @bind-Value="currentModel.Name" disabled="@isSuperAdminEdit" />
                        <ValidationMessage For="@(() => currentModel.Name)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Description</label>
                        <InputText class="form-control" @bind-Value="currentModel.Description" />
                    </div>

                    <div class="col-12 mt-4">
                        <label class="form-label fw-bold">Permissions autorisées :</label>
                        <div class="card">
                            <div class="card-body">
                                <div class="row">
                                    @foreach (var perm in allPermissions)
                                    {
                                        <div class="col-md-4 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       checked="@currentModel.PermissionIds.Contains(perm.Id)"
                                                       @onchange="(e) => TogglePermission(perm.Id, e.Value)"
                                                       id="perm_@perm.Id">
                                                <label class="form-check-label" for="perm_@perm.Id">
                                                    <strong>@perm.Code</strong> <br />
                                                    <small class="text-muted">@perm.Description</small>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-3 text-end">
                    <button type="button" class="btn btn-secondary me-2" @onclick="CancelForm">Annuler</button>
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                </div>
            </EditForm>
        </div>
    }

    <div class="row">
        @if (roles == null)
        {
            <p class="text-center">Chargement...</p>
        }
        else
        {
            @foreach (var role in roles)
            {
                <div class="col-md-4 mb-3">
                    <div class="card h-100 shadow-sm border-start border-4 border-primary">
                        <div class="card-body">
                            <h5 class="card-title d-flex justify-content-between">
                                @role.Name
                                @if (role.Name != "SuperAdmin")
                                {
                                    <div class="btn-group">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditRole(role.Id)">✏️</button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRole(role)">🗑️</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => EditRole(role.Id)">👁️ Voir</button>
                                }
                            </h5>
                            <p class="card-text text-muted">@role.Description</p>
                            <hr />
                            <h6>Droits :</h6>
                            @if (role.PermissionCodes.Any())
                            {
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var p in role.PermissionCodes)
                                    {
                                        <span class="badge bg-info text-dark">@p</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Aucune permission spécifique</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<RoleViewDto>? roles;
    private List<PermissionDto> allPermissions = new();

    private bool showForm = false;
    private bool editMode = false;
    private bool isSuperAdminEdit = false; // Pour verrouiller le nom SuperAdmin

    private RoleEditDto currentModel = new();
    private int editingRoleId = 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // On charge les permissions (la liste de référence) et les rôles existants
        allPermissions = await RoleService.GetAllPermissions();
        roles = await RoleService.GetRoles();
    }

    private void ShowAddForm()
    {
        currentModel = new RoleEditDto();
        editMode = false;
        isSuperAdminEdit = false;
        showForm = true;
    }

    private async Task EditRole(int id)
    {
        // On va chercher le détail complet (avec les IDs des perms cochées)
        currentModel = await RoleService.GetRoleForEdit(id);
        editingRoleId = id;
        editMode = true;
        isSuperAdminEdit = (currentModel.Name == "SuperAdmin");
        showForm = true;
    }

    // Logique pour ajouter/retirer l'ID de la liste quand on clique
    private void TogglePermission(int permId, object? checkedValue)
    {
        bool isChecked = (bool)(checkedValue ?? false);

        if (isChecked)
        {
            if (!currentModel.PermissionIds.Contains(permId))
                currentModel.PermissionIds.Add(permId);
        }
        else
        {
            currentModel.PermissionIds.Remove(permId);
        }
    }

    private void CancelForm()
    {
        showForm = false;
    }

    private async Task SaveRole()
    {
        if (editMode)
        {
            await RoleService.UpdateRole(editingRoleId, currentModel);
        }
        else
        {
            await RoleService.CreateRole(currentModel);
        }

        showForm = false;
        await LoadData();
    }

    private async Task DeleteRole(RoleViewDto role)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Supprimer le groupe {role.Name} ?"))
            return;

        await RoleService.DeleteRole(role.Id);
        await LoadData();
    }
}