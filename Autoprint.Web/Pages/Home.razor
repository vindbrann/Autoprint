@page "/Home"
@using Microsoft.AspNetCore.Components.Authorization
@using Radzen
@using Radzen.Blazor
@attribute [Authorize]

<PageTitle>Accueil</PageTitle>

<RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Gap="2rem" Style="min-height: 60vh; margin-top: 2rem;">
    
    <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
        <RadzenText TextStyle="TextStyle.DisplayH4" TextAlign="TextAlign.Center" Style="color: var(--rz-text-title-color);">
            Bienvenue, <span style="color: var(--rz-primary);">@username</span> !
        </RadzenText>
        <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center" Style="color: var(--rz-text-secondary-color);">
            Votre tableau de bord d'administration est prêt.
        </RadzenText>
    </RadzenStack>

    <RadzenDivider Style="width: 50%;" />

    <RadzenCard Variant="Variant.Flat" Class="rz-p-4" Style="max-width: 600px; border-left: 4px solid var(--rz-info);">
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
            <RadzenIcon Icon="info" Style="font-size: 2rem; color: var(--rz-info);" />
            <RadzenText TextStyle="TextStyle.Body1" Style="margin: 0;">
                Sélectionnez une option dans le menu de gauche pour commencer.
            </RadzenText>
        </RadzenStack>
    </RadzenCard>

</RadzenStack>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = default!;

    private string? username;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;

        if (user.Identity is not null && user.Identity.IsAuthenticated)
        {
            username = user.Identity.Name;
        }
    }
}