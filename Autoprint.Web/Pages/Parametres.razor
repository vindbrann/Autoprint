@page "/parametres"
@using Autoprint.Shared
@using System.Text.Json
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Configuration</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>⚙️ Configuration & Outils</h3>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Chargement...</span>
            </div>
        </div>
    }
    else
    {
        <ul class="nav nav-tabs mb-4 align-items-end">
            <li class="nav-item">
                <button class="nav-link @(activeTab == "import" ? "active" : "")" type="button" @onclick="@(() => activeTab = "import")">
                    <i class="bi bi-box-seam-fill me-2"></i>Import / Scan
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "smtp" ? "active" : "")" type="button" @onclick="@(() => activeTab = "smtp")">
                    <i class="bi bi-envelope-at-fill me-2"></i>SMTP
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "nommage" ? "active" : "")" type="button" @onclick="@(() => activeTab = "nommage")">
                    <i class="bi bi-tags-fill me-2"></i>Nommage
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link @(activeTab == "securite" ? "active" : "")" type="button" @onclick="@(() => activeTab = "securite")">
                    <i class="bi bi-shield-lock-fill me-2"></i>Sécurité
                </button>
            </li>
        </ul>

        <div class="card shadow-sm border-top-0" style="border-top-left-radius: 0; border-top-right-radius: 0;">
            <div class="card-body p-4">

                @* --- ONGLET IMPORT (NOUVELLE VERSION LÉGÈRE) --- *@
                @if (activeTab == "import")
                {
                    <h5 class="card-title mb-3 text-primary">Outils d'importation</h5>
                    <p class="text-muted">Utilisez ces outils pour peupler votre base de données à partir de l'existant Windows.</p>

                    <div class="row g-4 mt-2">
                        <div class="col-md-6">
                            <div class="card h-100 text-center border-primary mb-3 hover-shadow">
                                <div class="card-body d-flex flex-column align-items-center justify-content-center p-5">
                                    <i class="bi bi-hdd-network text-primary" style="font-size: 3rem;"></i>
                                    <h4 class="mt-3">Pilotes</h4>
                                    <p class="text-muted">Scanner les pilotes installés sur le serveur local.</p>
                                    <button class="btn btn-primary mt-2 px-4" @onclick="() => showDriversModal = true">
                                        Ouvrir le Scan Pilotes
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card h-100 text-center border-info mb-3 hover-shadow">
                                <div class="card-body d-flex flex-column align-items-center justify-content-center p-5">
                                    <i class="bi bi-printer text-info" style="font-size: 3rem;"></i>
                                    <h4 class="mt-3">Imprimantes</h4>
                                    <p class="text-muted">Scanner les files d'attente (Local ou Distant).</p>
                                    <button class="btn btn-info text-white mt-2 px-4" @onclick="() => showPrintersModal = true">
                                        Ouvrir le Scan Imprimantes
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* --- AUTRES ONGLETS (SMTP, NOMMAGE, SECURITE) --- *@
                @* ... Code identique à la version précédente pour ces blocs, je le remets complet pour éviter les trous ... *@

                @if (activeTab == "smtp")
                {
                    <h5 class="card-title mb-3 text-primary">Serveur SMTP</h5>
                    <div class="row g-3">
                        <div class="col-md-8"> <label class="form-label">Hôte</label> <input class="form-control" @bind="model.SmtpHost" /> </div>
                        <div class="col-md-4"> <label class="form-label">Port</label> <input type="number" class="form-control" @bind="model.SmtpPort" /> </div>
                        <div class="col-md-6"> <label class="form-label">User</label> <input class="form-control" @bind="model.SmtpUser" /> </div>
                        <div class="col-md-6"> <label class="form-label">Pass</label> <input type="password" class="form-control" @bind="model.SmtpPass" /> </div>
                        <div class="col-md-6"> <label class="form-label">From</label> <input class="form-control" @bind="model.SmtpFromAddress" /> </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <div class="form-check form-switch mb-2">
                                <input class="form-check-input" type="checkbox" id="ssl" @bind="model.SmtpEnableSsl">
                                <label class="form-check-label" for="ssl">SSL / TLS</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 text-end">
                        <button class="btn btn-outline-primary btn-sm" @onclick="TesterEmail" disabled="@testEnCours">Test Email</button>
                    </div>
                }

                @if (activeTab == "nommage")
                {
                    <h5 class="card-title mb-3 text-primary">Règles de Nommage</h5>
                    <div class="row">
                        <div class="col-md-7">
                            <div class="card bg-light border-primary mb-4">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="namingOn" @bind="model.NamingEnabled">
                                            <label class="form-check-label fw-bold" for="namingOn">Activer</label>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="RenommerToutesImprimantes" disabled="@(!model.NamingEnabled)">Renommer Imprimantes</button>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="form-check form-switch">
                                            <input class="form-check-input" type="checkbox" id="shareOn" @bind="model.NamingSameShare" disabled="@IsNamingDisabled">
                                            <label class="form-check-label" for="shareOn">Appliquer au Partage</label>
                                        </div>
                                        <button class="btn btn-sm btn-outline-success" @onclick="RenommerTousPartages" disabled="@(!model.NamingSameShare || !model.NamingEnabled)">Renommer Partages</button>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Template</label>
                                <input class="form-control font-monospace" @bind="model.NamingTemplate" disabled="@IsNamingDisabled" />
                            </div>
                        </div>
                        <div class="col-md-5">
                            <div class="card bg-white border-info">
                                <div class="card-body">
                                    <div class="row g-2">
                                        <div class="col-6"><input class="form-control form-control-sm" @bind="testLieu" placeholder="Lieu" /></div>
                                        <div class="col-6"><input class="form-control form-control-sm" @bind="testLieuCode" placeholder="Code" /></div>
                                        <div class="col-12"><input class="form-control form-control-sm" @bind="testIp" placeholder="IP" /></div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-info w-100 mt-2" @onclick="SimulerNom">Simuler</button>
                                    @if (!string.IsNullOrEmpty(previewResult))
                                    {
                                        <div class="mt-2 text-center fw-bold">@previewResult</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @if (activeTab == "securite")
                {
                    <h5 class="card-title mb-3 text-primary">Sécurité</h5>
                    <label class="form-label">Expiration (jours)</label>
                    <input type="number" class="form-control" @bind="model.PasswordExpirationDays" style="max-width:150px" />
                }

            </div>

            @if (activeTab != "import")
            {
                <div class="card-footer bg-white p-3 d-flex justify-content-end border-top">
                    <button class="btn btn-success px-4" @onclick="Sauvegarder" disabled="@sauvegardeEnCours">
                        @if (sauvegardeEnCours)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <span>Enregistrer la configuration</span>
                    </button>
                </div>
            }
        </div>
    }
</div>

<ScanDriversModal Show="showDriversModal" OnCancel="() => showDriversModal = false" />
<ScanPrintersModal Show="showPrintersModal" OnCancel="() => showPrintersModal = false" />

@code {
    private string activeTab = "import";
    private SettingsModel model = new();
    private bool isLoading = true;
    private bool sauvegardeEnCours = false;
    private bool testEnCours = false;
    private string testEmailTo = "";

    // Gestion des Modales
    private bool showDriversModal = false;
    private bool showPrintersModal = false;

    private string testLieu = "Bur", testLieuCode = "B", testImpCode = "P1", testIp = "1.1.1.1", previewResult = "";
    private bool IsNamingDisabled => !model.NamingEnabled;

    private class SettingsModel
    {
        public string SmtpHost { get; set; } = "";
        public int SmtpPort { get; set; } = 25;
        public string SmtpUser { get; set; } = "";
        public string SmtpPass { get; set; } = "";
        public bool SmtpEnableSsl { get; set; } = false;
        public string SmtpFromAddress { get; set; } = "";
        public string NamingTemplate { get; set; } = "";
        public bool NamingEnabled { get; set; } = false;
        public bool NamingSameShare { get; set; } = false;
        public int PasswordExpirationDays { get; set; } = 90;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var settings = await Http.GetFromJsonAsync<List<ServerSetting>>("api/Settings");
            model.SmtpHost = GetVal(settings, "SmtpHost");
            model.SmtpPort = int.Parse(GetVal(settings, "SmtpPort", "25"));
            model.SmtpUser = GetVal(settings, "SmtpUser");
            model.SmtpPass = GetVal(settings, "SmtpPass");
            model.SmtpEnableSsl = bool.Parse(GetVal(settings, "SmtpEnableSsl", "false"));
            model.SmtpFromAddress = GetVal(settings, "SmtpFromAddress");
            model.NamingTemplate = GetVal(settings, "NamingTemplate");
            model.NamingEnabled = bool.Parse(GetVal(settings, "NamingEnabled", "false"));
            model.NamingSameShare = bool.Parse(GetVal(settings, "NamingSameShare", "false"));
            model.PasswordExpirationDays = int.Parse(GetVal(settings, "PasswordExpirationDays", "90"));
        }
        catch (Exception ex) { Console.WriteLine("Error loading settings: " + ex.Message); }
        finally { isLoading = false; }
    }

    private string GetVal(List<ServerSetting>? list, string key, string def = "") => list?.FirstOrDefault(s => s.Key == key)?.Value ?? def;

    private async Task Sauvegarder()
    {
        sauvegardeEnCours = true;
        try
        {
            var res = await Http.PostAsJsonAsync("api/Settings/Save", model);
            if (res.IsSuccessStatusCode) await JS.InvokeVoidAsync("alert", "Sauvegardé !");
            else await JS.InvokeVoidAsync("alert", "Erreur: " + await res.Content.ReadAsStringAsync());
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Erreur technique: " + ex.Message); }
        finally { sauvegardeEnCours = false; }
    }

    private async Task RenommerToutesImprimantes() { await ActionNaming("api/Naming/ApplyToNames", "Imprimantes renommées."); }
    private async Task RenommerTousPartages() { await ActionNaming("api/Naming/ApplyToShares", "Partages renommés."); }

    private async Task ActionNaming(string url, string successMsg)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Confirmer l'action ?")) return;
        await Http.PostAsJsonAsync("api/Settings/Save", model);
        var res = await Http.PostAsync(url, null);
        if (res.IsSuccessStatusCode) await JS.InvokeVoidAsync("alert", successMsg);
    }

    private async Task TesterEmail()
    {
        if (string.IsNullOrEmpty(testEmailTo)) return;
        testEnCours = true;
        try
        {
            var dto = new { Host = model.SmtpHost, Port = model.SmtpPort, User = model.SmtpUser, Password = model.SmtpPass, Ssl = model.SmtpEnableSsl, From = model.SmtpFromAddress, To = testEmailTo };
            var res = await Http.PostAsJsonAsync("api/Settings/TestEmail", dto);
            if (res.IsSuccessStatusCode) await JS.InvokeVoidAsync("alert", "✅ Email envoyé !");
            else await JS.InvokeVoidAsync("alert", "❌ Erreur SMTP: " + await res.Content.ReadAsStringAsync());
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Erreur technique: " + ex.Message); }
        finally { testEnCours = false; }
    }

    private async Task SimulerNom()
    {
        var dto = new
        {
            Template = model.NamingTemplate,
            Ip = testIp,
            LieuNom = testLieu,
            LieuCode = testLieuCode,
            ImpCode = testImpCode,
            ModeleNom = "LaserJet",
            MarqueNom = "HP"
        };
        var response = await Http.PostAsJsonAsync("api/Naming/Preview", dto);
        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<JsonElement>();
            if (result.TryGetProperty("generatedName", out var prop))
            {
                previewResult = prop.GetString() ?? "";
            }
        }
    }
}