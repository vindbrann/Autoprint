@page "/login"
@layout Autoprint.Web.Layout.EmptyLayout
@using Autoprint.Shared
@using Autoprint.Shared.DTOs
@using Autoprint.Web.Services
@using Blazored.LocalStorage
@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject HttpClient Http
@inject IJSRuntime JS
@inject ILocalStorageService LocalStorage

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-md-7 col-lg-5">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden mt-5">
                <div class="bg-dark text-white text-center py-4">
                    <i class="bi bi-printer-fill" style="font-size: 3rem;"></i>
                    <h3 class="fw-bold mt-2">Autoprint Serveur</h3>
                </div>

                <div class="card-body p-5 bg-white">

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert @(ErrorMessage.Contains("droit") ? "alert-warning" : "alert-danger") d-flex align-items-center" role="alert">
                            <i class="bi @(ErrorMessage.Contains("droit") ? "bi-lock-fill" : "bi-exclamation-triangle-fill") me-2"></i>
                            <div>@ErrorMessage</div>
                        </div>
                    }

                    @if (!forgotPasswordMode)
                    {
                        <EditForm Model="@loginRequest" OnValidSubmit="HandleLogin">
                            <DataAnnotationsValidator />

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="loginRequest.Username" id="username" class="form-control" placeholder="Nom d'utilisateur" />
                                <label for="username">Identifiant</label>
                            </div>

                            <div class="form-floating mb-3">
                                <InputText @bind-Value="loginRequest.Password" type="password" id="password" class="form-control" placeholder="Mot de passe" />
                                <label for="password">Mot de passe</label>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <InputCheckbox @bind-Value="loginRequest.RememberMe" id="rememberMe" class="form-check-input" />
                                    <label class="form-check-label small" for="rememberMe">Retenir mon identifiant</label>
                                </div>

                                <button type="button" class="btn btn-link text-decoration-none small" @onclick="() => forgotPasswordMode = true">
                                    Mot de passe oublié ?
                                </button>
                            </div>

                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm" disabled="@isBusy">
                                    @if (isBusy)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    SE CONNECTER
                                </button>
                            </div>
                        </EditForm>
                    }
                    else
                    {
                        <div class="text-center mb-4">
                            <h5 class="text-primary">Récupération de compte</h5>
                            <p class="text-muted small">Entrez votre identifiant ou votre email.<br />Si le compte existe, vous recevrez un mot de passe temporaire.</p>
                        </div>

                        <div class="form-floating mb-3">
                            <input @bind="forgotEmailOrUser" class="form-control" placeholder="Email ou Identifiant" />
                            <label>Email ou Identifiant</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary" @onclick="HandleForgotPassword" disabled="@isBusy">
                                @if (isBusy)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                Envoyer la demande
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="() => forgotPasswordMode = false">
                                Retour à la connexion
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<PasswordModal Show="showExpiredModal"
               IsForced="true"
               OnCancel="CancelExpired"
               OnConfirm="ChangeExpiredPassword" />

@code {
    private LoginRequest loginRequest = new LoginRequest();
    private string ErrorMessage = string.Empty;
    private bool isBusy = false;
    private bool forgotPasswordMode = false;
    private string forgotEmailOrUser = "";
    private bool showExpiredModal = false;

    // CHARGEMENT DU LOGIN SAUVEGARDÉ
    protected override async Task OnInitializedAsync()
    {
        var savedUser = await LocalStorage.GetItemAsync<string>("saved_username");
        if (!string.IsNullOrEmpty(savedUser))
        {
            loginRequest.Username = savedUser;
            loginRequest.RememberMe = true;
        }
    }

    private async Task HandleLogin()
    {
        isBusy = true;
        ErrorMessage = "";

        try
        {
            var result = await AuthService.Login(loginRequest);

            // LOGIQUE DE SAUVEGARDE DU LOGIN
            if (loginRequest.RememberMe)
            {
                await LocalStorage.SetItemAsync("saved_username", loginRequest.Username);
            }
            else
            {
                await LocalStorage.RemoveItemAsync("saved_username");
            }

            if (result.PasswordExpired)
            {
                showExpiredModal = true;
            }
            else
            {
                NavigationManager.NavigateTo("/");
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandleForgotPassword()
    {
        if (string.IsNullOrWhiteSpace(forgotEmailOrUser)) return;
        isBusy = true;
        try
        {
            var request = new ForgotPasswordRequest { EmailOrUsername = forgotEmailOrUser };
            var response = await Http.PostAsJsonAsync("api/auth/forgot-password", request);
            await JS.InvokeVoidAsync("alert", "Si les informations sont correctes, un email a été envoyé.");
            forgotPasswordMode = false;
        }
        catch { ErrorMessage = "Impossible de contacter le serveur."; }
        finally { isBusy = false; }
    }

    private void CancelExpired()
    {
        showExpiredModal = false;
        ((Autoprint.Web.Services.AuthService)AuthService).Logout();
        loginRequest = new LoginRequest();
        ErrorMessage = "Le changement de mot de passe est obligatoire.";
    }

    private async Task ChangeExpiredPassword(ChangePasswordDto dto)
    {
        try
        {
            var res = await Http.PutAsJsonAsync("api/users/change-password", dto);
            if (res.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Mot de passe mis à jour avec succès !");
                showExpiredModal = false;
                NavigationManager.NavigateTo("/");
            }
            else
            {
                var error = await res.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", "Erreur : " + error);
            }
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", "Erreur technique : " + ex.Message); }
    }
}