@using Autoprint.Shared.DTOs
@using Autoprint.Shared.Enums

@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title"><i class="bi bi-arrow-repeat"></i> Synchronisation - Aperçu des modifications</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="OnCancel"></button>
                </div>

                <div class="modal-body">
                    @if (Items == null)
                    {
                        <div class="text-center p-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <p class="mt-2">Analyse des changements en cours...</p>
                        </div>
                    }
                    else if (Items.Count == 0)
                    {
                        <div class="alert alert-success text-center">
                            <i class="bi bi-check-circle-fill fs-3"></i><br />
                            Aucune modification en attente. Tout est synchronisé !
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Sélectionnez les opérations à appliquer sur le serveur d'impression Windows.
                        </div>

                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center" style="width: 40px;">
                                        <input type="checkbox" class="form-check-input" @onchange="ToggleSelectAll" checked="@AreAllSelected" />
                                    </th>
                                    <th>Action</th>
                                    <th>Imprimante</th>
                                    <th>Détails</th>
                                    <th>Modifié par</th>
                                    <th>Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Items)
                                {
                                    // Calcul du style de la ligne (Bordure colorée)
                                    string rowClass = item.Status switch
                                    {
                                        PrinterStatus.PendingCreation => "border-start border-5 border-success bg-success bg-opacity-10",
                                        PrinterStatus.PendingDelete => "border-start border-5 border-danger bg-danger bg-opacity-10",
                                        PrinterStatus.PendingUpdate => "border-start border-5 border-warning",
                                        _ => ""
                                    };

                                    <tr class="@rowClass">
                                        <td class="text-center">
                                            <input type="checkbox" class="form-check-input" @bind="item.IsSelected" />
                                        </td>
                                        <td>
                                            @if (item.Status == PrinterStatus.PendingCreation)
                                            {
                                                <span class="badge bg-success">CRÉATION</span>
                                            }
                                            else if (item.Status == PrinterStatus.PendingDelete)
                                            {

                                                <span class="badge bg-danger">SUPPRESSION</span>
                                            }
                                            else
                                            {

                                                <span class="badge bg-warning text-dark">MODIFICATION</span>
                                            }
                                        </td>
                                        <td class="fw-bold">@item.NomImprimante</td>
                                        <td class="small text-muted">@item.Details</td>
                                        <td><i class="bi bi-person-fill"></i> @item.ModifiePar</td>
                                        <td class="small">@item.DateModification.ToLocalTime().ToString("g")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="modal-footer">
                    <div class="me-auto">
                        <span class="fw-bold">@Items?.Count(i => i.IsSelected)</span> élément(s) sélectionné(s)
                    </div>
                    <button type="button" class="btn btn-secondary" @onclick="OnCancel">Annuler</button>

                    @if (Items != null && Items.Count > 0)
                    {
                        <button type="button" class="btn btn-primary" @onclick="ConfirmerSynchro" disabled="@(!Items.Any(i => i.IsSelected))">
                            <i class="bi bi-play-fill"></i> Lancer la Synchronisation
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public List<SyncPreviewDto>? Items { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public EventCallback<List<int>> OnConfirm { get; set; } // Renvoie les IDs choisis

    private bool AreAllSelected => Items != null && Items.All(i => i.IsSelected);

    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool val = (bool)(e.Value ?? false);
        if (Items != null)
        {
            foreach (var item in Items) item.IsSelected = val;
        }
    }

    private async Task ConfirmerSynchro()
    {
        var selectedIds = Items?.Where(i => i.IsSelected).Select(i => i.Id).ToList();
        if (selectedIds != null && selectedIds.Any())
        {
            await OnConfirm.InvokeAsync(selectedIds);
        }
    }
}