@inherits LayoutComponentBase
@using System.Security.Claims
@using Autoprint.Shared.DTOs
@using Autoprint.Web.Pages
@using Autoprint.Web.Services
@using Radzen
@using Radzen.Blazor
@using Blazored.LocalStorage

@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IAuthService AuthService
@inject IJSRuntime JS
@inject ThemeService ThemeService
@inject ILocalStorageService LocalStorage


<RadzenComponents />
<RadzenTheme />

<AuthorizeView>
    <Authorized>
        @if (IsBlocked(context.User) && !processCompleted)
        {
            <SecurityWall Show="true" OnSuccess="HandleSuccess" OnLogout="HandleLogout" />
        }
        else
        {
            <RadzenLayout Style="height: 100vh; display: flex;">
                <RadzenSidebar Expanded="true" Style="width: 280px; min-width: 280px; display: flex; flex-direction: column; z-index: 1;">
                    <NavMenu />
                </RadzenSidebar>

                <RadzenBody Style="flex: 1; overflow: auto;">
                    <div class="rz-p-4">
                        @Body
                    </div>
                </RadzenBody>
            </RadzenLayout>
        }
    </Authorized>

    <NotAuthorized>
        <div class="login-container d-flex align-items-center justify-content-center" style="min-height: 100vh; background-color: var(--rz-base-200);">
            <div class="w-100" style="max-width: 500px;">
                @Body
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool processCompleted = false;

    // --- [NOUVEAU] CHARGEMENT DU THEME ---
    protected override async Task OnInitializedAsync()
    {
        // On récupère le thème sauvegardé, sinon par défaut "material"
        var savedTheme = await LocalStorage.GetItemAsync<string>("user_theme");
        if (string.IsNullOrEmpty(savedTheme)) savedTheme = "material";

        ThemeService.SetTheme(savedTheme);
    }
    // -------------------------------------

    private bool IsBlocked(ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == "ForcePasswordChange" && c.Value == "true");
    }

    private async Task HandleSuccess()
    {
        processCompleted = true;
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("alert", "✅ Mot de passe mis à jour ! Vous allez être redirigé.");
        await HandleLogout();
    }

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        NavManager.NavigateTo("/login", true);
    }
}