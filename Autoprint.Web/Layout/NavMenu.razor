@using Autoprint.Web.Services
@inject IAuthService AuthService
@inject NavigationManager NavManager

<div class="top-row ps-3 navbar navbar-dark border-bottom border-secondary bg-black bg-opacity-25">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <i class="bi bi-hdd-network-fill me-3 fs-4"></i>
            <span class="fw-bold">Autoprint</span>
        </a>
    </div>
</div>

<div class="d-flex flex-column" style="height: calc(100vh - 3.5rem);">

    <div class="flex-grow-1 overflow-auto custom-scrollbar">
        <nav class="flex-column pt-3">

            <AuthorizeView>
                <Authorized Context="menuAuth">

                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                            <span class="bi bi-speedometer2" aria-hidden="true"></span> Tableau de bord
                        </NavLink>
                    </div>

                    @if (CanShowGestionSection(menuAuth.User))
                    {
                        <div class="nav-item px-3 mt-3 mb-1">
                            <span class="text-uppercase text-white-50 fw-bold small ps-3 d-flex align-items-center"
                                  style="font-size: 0.65rem; letter-spacing: 1px;">
                                <i class="bi bi-briefcase-fill me-2 fs-6"></i> Gestion
                            </span>
                        </div>

                        <AuthorizeView Policy="PRINTER_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="imprimantes">
                                    <span class="bi bi-printer" aria-hidden="true"></span> Imprimantes
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="LOCATION_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="lieux">
                                    <span class="bi bi-geo-alt" aria-hidden="true"></span> Lieux
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="BRAND_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="marques">
                                    <span class="bi bi-tags" aria-hidden="true"></span> Marques
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="MODEL_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="modeles">
                                    <span class="bi bi-file-earmark-text" aria-hidden="true"></span> Modèles
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="DRIVER_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="pilotes">
                                    <span class="bi bi-usb-drive" aria-hidden="true"></span> Pilotes
                                </NavLink>
                            </div>
                        </AuthorizeView>
                    }

                    @if (CanShowSystemSection(menuAuth.User))
                    {
                        <div class="nav-item px-3 mt-4 mb-1">
                            <span class="text-uppercase text-white-50 fw-bold small ps-3 d-flex align-items-center"
                                  style="font-size: 0.65rem; letter-spacing: 1px;">
                                <i class="bi bi-cpu-fill me-2 fs-6"></i> Système
                            </span>
                        </div>

                        <AuthorizeView Policy="SETTINGS_MANAGE">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="parametres">
                                    <span class="bi bi-gear" aria-hidden="true"></span> Paramètres
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="USER_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="users">
                                    <span class="bi bi-people-fill" aria-hidden="true"></span> Utilisateurs
                                </NavLink>
                            </div>
                        </AuthorizeView>

                        <AuthorizeView Policy="ROLE_READ">
                            <div class="nav-item px-3">
                                <NavLink class="nav-link" href="roles">
                                    <span class="bi bi-shield-lock-fill" aria-hidden="true"></span> Rôles & Droits
                                </NavLink>
                            </div>
                        </AuthorizeView>
                    }

                </Authorized>
            </AuthorizeView>
        </nav>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="p-3 bg-black bg-opacity-50 border-top border-secondary mt-auto">
                <div class="d-flex align-items-center justify-content-between px-1">

                    <div class="d-flex align-items-center overflow-hidden">
                        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white me-2"
                             style="width: 36px; height: 36px; min-width: 36px;">
                            <span class="fs-5">@GetInitials(GetNomAffichage(context.User))</span>
                        </div>

                        <div class="d-flex flex-column overflow-hidden" style="line-height: 1.2;">
                            <span class="fw-bold text-white text-truncate" style="font-size: 0.9rem;"
                                  title="@GetNomAffichage(context.User)">
                                @GetNomAffichage(context.User)
                            </span>
                            <span class="text-white-50 small" style="font-size: 0.7rem;">Connecté</span>
                        </div>
                    </div>

                    <button class="btn btn-link text-danger p-0 ms-2" @onclick="BeginLogout" title="Déconnecter">
                        <i class="bi bi-power fs-5"></i>
                    </button>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

</div>

@code {
    private async Task BeginLogout()
    {
        await AuthService.Logout();
        NavManager.NavigateTo("/login");
    }

    private string GetNomAffichage(System.Security.Claims.ClaimsPrincipal user)
    {
        var display = user.FindFirst("DisplayName")?.Value;
        return !string.IsNullOrEmpty(display) ? display : user.Identity?.Name ?? "?";
    }

    private string GetInitials(string? name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        return name.Substring(0, 1).ToUpper();
    }

        private bool CanShowSystemSection(System.Security.Claims.ClaimsPrincipal user)
    {
            return user.HasClaim(c => c.Type == "Permission" &&
                                 (c.Value == "SETTINGS_MANAGE" ||
                                  c.Value == "USER_READ" ||
                                  c.Value == "ROLE_READ"));
    }

    private bool CanShowGestionSection(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.HasClaim(c => c.Type == "Permission" &&
                                 (c.Value == "PRINTER_READ" ||
                                  c.Value == "LOCATION_READ" ||
                                  c.Value == "BRAND_READ" ||
                                  c.Value == "MODEL_READ" ||
                                  c.Value == "DRIVER_READ"));
    }
}