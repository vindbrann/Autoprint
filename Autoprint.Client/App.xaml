<Application x:Class="Autoprint.Client.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Inherit" 
                                             PrimaryColor="Grey" 
                                             SecondaryColor="Lime" />

                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ContextMenu x:Key="TrayMenu" 
                         Background="{DynamicResource MaterialDesignPaper}"
                         TextElement.Foreground="{DynamicResource MaterialDesignBody}">

                <MenuItem Header="Mes Imprimantes" Click="MenuOpen_Click">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Printer" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Options" Click="MenuOptions_Click">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Cog" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem Header="Nettoyer les installations" Click="MenuManage_Click">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="PrinterOff" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Header="Quitter" Click="MenuExit_Click">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="ExitToApp" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>

            <tb:TaskbarIcon x:Key="MainNotifyIcon"
                            ToolTipText="Autoprint Agent"
                            IconSource="pack://application:,,,/Autoprint.ico"
                            ContextMenu="{StaticResource TrayMenu}"
                            TrayMouseDoubleClick="OnTrayDoubleClick"
                            TrayBalloonTipClicked="OnTrayBalloonTipClicked"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>