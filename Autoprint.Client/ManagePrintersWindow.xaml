<Window x:Class="Autoprint.Client.ManagePrintersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        Title="Gestion Imprimantes" Width="400" MaxHeight="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border CornerRadius="0" Background="{DynamicResource MaterialDesignPaper}" ClipToBounds="True" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignBody}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="15" MouseDown="Header_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PrinterCheck" Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="MES INSTALLATIONS" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"
                            Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Click="BtnFermer_Click">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <StackPanel Grid.Row="1" Margin="20">
                <TextBlock Text="Imprimantes Réseau Mappées" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,5" Opacity="0.6"/>
                <TextBlock Text="Seules les imprimantes connectées apparaissent ici." FontSize="11" Opacity="0.4" FontStyle="Italic" Margin="0,0,0,15"/>

                <TextBlock Text="Aucune imprimante installée." 
                           Visibility="{Binding HasNoPrinters, Converter={StaticResource BoolToVis}}" 
                           HorizontalAlignment="Center" Margin="20" Opacity="0.5"/>

                <ItemsControl ItemsSource="{Binding InstalledPrinters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,10" Padding="10" UniformCornerRadius="6" materialDesign:ElevationAssist.Elevation="Dp1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <materialDesign:PackIcon Kind="NetworkOutline" Width="24" Height="24" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,15,0"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding FullName}" FontSize="10" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Button Grid.Column="2" 
                                            Style="{StaticResource MaterialDesignFlatButton}" 
                                            Command="{Binding DeleteCommand}"
                                            Foreground="{DynamicResource MaterialDesignErrorBrush}"
                                            ToolTip="Désinstaller (Unmap)">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"/>
                                    </Button>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </Grid>
    </Border>
</Window>