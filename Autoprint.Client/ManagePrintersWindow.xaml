<Window x:Class="Autoprint.Client.ManagePrintersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:Autoprint.Client.Converters"
        mc:Ignorable="d"
        Title="Gestion Imprimantes" Width="450" Height="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{DynamicResource MaterialDesignFont}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InvertBooleanConverter x:Key="InvertBooleanConverter" />
    </Window.Resources>

    <Border CornerRadius="8" Background="{DynamicResource MaterialDesignPaper}" ClipToBounds="True" BorderThickness="1" BorderBrush="{DynamicResource MaterialDesignDivider}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="15" MouseDown="Header_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PrinterSettings" Width="22" Height="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="MES INSTALLATIONS" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-5,0"
                            Style="{StaticResource MaterialDesignIconForegroundButton}" 
                            Click="BtnFermer_Click"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBooleanConverter}}">
                        <materialDesign:PackIcon Kind="Close" />
                    </Button>
                </Grid>
            </materialDesign:ColorZone>

            <ProgressBar Grid.Row="1" IsIndeterminate="True" Height="4" 
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" 
                         Background="Transparent" BorderThickness="0"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="15">
                <StackPanel>
                    <TextBlock Text="Imprimantes Réseau Mappées" Style="{StaticResource MaterialDesignSubtitle1TextBlock}" Margin="0,0,0,5" Opacity="0.6"/>
                    <TextBlock Text="Les favoris (★) sont protégés du nettoyage." FontSize="11" Opacity="0.4" FontStyle="Italic" Margin="0,0,0,15"/>

                    <TextBlock Text="Aucune imprimante réseau installée."
                               Visibility="{Binding HasNoPrinters, Converter={StaticResource BoolToVis}}" 
                               HorizontalAlignment="Center" Margin="20" Opacity="0.5"/>

                    <ItemsControl ItemsSource="{Binding InstalledPrinters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Margin="0,0,0,8" Padding="12" UniformCornerRadius="6" materialDesign:ElevationAssist.Elevation="Dp1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <materialDesign:PackIcon Kind="{Binding IconKind}" 
                                                                 Width="24" Height="24" 
                                                                 VerticalAlignment="Center" Margin="0,0,15,0"
                                                                 Opacity="{Binding IconOpacity}">
                                            <materialDesign:PackIcon.Style>
                                                <Style TargetType="materialDesign:PackIcon">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                            <Setter Property="Foreground" Value="#FFC107"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </materialDesign:PackIcon.Style>
                                        </materialDesign:PackIcon>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding FullName}" FontSize="10" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <Button Grid.Column="2" 
                                                Style="{StaticResource MaterialDesignFlatButton}" 
                                                Command="{Binding DeleteCommand}"
                                                IsEnabled="{Binding DataContext.IsBusy, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource InvertBooleanConverter}}"
                                                Foreground="{DynamicResource MaterialDesignErrorBrush}"
                                                ToolTip="Désinstaller (Unmap)">
                                            <materialDesign:PackIcon Kind="DeleteOutline" Width="20" Height="20"/>
                                        </Button>
                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MaterialDesignDivider}" Padding="15" Background="{DynamicResource MaterialDesignCardBackground}">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}" 
                               VerticalAlignment="Center" HorizontalAlignment="Left"
                               FontStyle="Italic" Opacity="0.7" FontSize="11" 
                               TextTrimming="CharacterEllipsis" MaxWidth="220"/>

                    <Button HorizontalAlignment="Right" 
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding CleanCommand}"
                            Visibility="{Binding CanClean, Converter={StaticResource BoolToVis}}"
                            ToolTip="Supprimer toutes les imprimantes NON favorites">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Broom" Margin="0,0,8,0"/>
                            <TextBlock Text="NETTOYER"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>